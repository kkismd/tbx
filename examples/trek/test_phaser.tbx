USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "combat.tbx"
USE "../../lib/tests/helper.tbx"

DEF SET_ENTERPRISE_POS(SX, SY)
  LET ENT_SX = SX
  LET ENT_SY = SY
END

DEF SET_KLINGON(I, SX, SY, E)
  LET @K_X[I] = SX
  LET @K_Y[I] = SY
  LET @K_E[I] = E
END

DEF SET_CURRENT_QUADRANT_SUMMARY(KLINGON_COUNT, BASE_COUNT, STAR_COUNT)
  LET @GALAXY[ENT_QX, ENT_QY] = KLINGON_COUNT * 100 + BASE_COUNT * 10 + STAR_COUNT
END

DEF SETUP_DESTROY_KLINGON_SCENARIO()
  INIT_GAME
  LET ENT_QX = 4
  LET ENT_QY = 5
  LET ENT_SX = 1
  LET ENT_SY = 1
  CLEAR_SECTOR
  LET @CHART[ENT_QX, ENT_QY] = 999
  SET_CURRENT_QUADRANT_SUMMARY 2, 1, 4
  LET KLINGONS_HERE = 2
  LET KLINGONS_LEFT = 7
  SET_KLINGON 1, 6, 7, 125
  SET_KLINGON 2, 2, 3, 90
  SET_KLINGON 3, 4, 4, 0
  LET @SECTOR[6, 7] = 2
  LET @SECTOR[2, 3] = 2
END

DEF SETUP_FIRE_PHASERS_SCENARIO()
  INIT_GAME
  LET ENT_QX = 4
  LET ENT_QY = 5
  LET ENT_SX = 1
  LET ENT_SY = 1
  CLEAR_SECTOR
  LET ENERGY = 1000
  SET_CURRENT_QUADRANT_SUMMARY 2, 1, 4
  LET @CHART[ENT_QX, ENT_QY] = 214
  LET KLINGONS_HERE = 2
  LET KLINGONS_LEFT = 7
  SET_KLINGON 1, 4, 1, 150
  SET_KLINGON 2, 1, 4, 80
  SET_KLINGON 3, 7, 7, 0
  LET @SECTOR[4, 1] = 2
  LET @SECTOR[1, 4] = 2
END

DEF SETUP_KLINGON_ATTACK_SCENARIO()
  INIT_GAME
  LET ENT_QX = 4
  LET ENT_QY = 5
  LET ENT_SX = 1
  LET ENT_SY = 1
  CLEAR_SECTOR
  LET SHIELDS = 400
  LET DOCKED = FALSE
  LET KLINGONS_HERE = 2
  LET KLINGONS_LEFT = 2
  SET_KLINGON 1, 3, 1, 100
  SET_KLINGON 2, 1, 5, 80
  SET_KLINGON 3, 7, 7, 0
  LET @SECTOR[3, 1] = 2
  LET @SECTOR[1, 5] = 2
END

# helper and geometry
DEF TEST_KLINGON_ALIVE_TRUE_WHEN_ENERGY_POSITIVE()
  INIT_GAME
  SET_KLINGON 1, 5, 5, 200
  ASSERT KLINGON_ALIVE(1)
END

DEF TEST_KLINGON_ALIVE_FALSE_WHEN_ENERGY_ZERO()
  INIT_GAME
  SET_KLINGON 1, 5, 5, 0
  ASSERT_FALSE KLINGON_ALIVE(1)
END

DEF TEST_KLINGON_ALIVE_FALSE_FOR_OUT_OF_RANGE_INDEX()
  INIT_GAME
  ASSERT_FALSE KLINGON_ALIVE(0)
  ASSERT_FALSE KLINGON_ALIVE(4)
END

DEF TEST_KLINGON_ALIVE_FALSE_FOR_UNUSED_NONE_SLOT()
  ASSERT_FALSE KLINGON_ALIVE(1)
END

DEF TEST_DIST_TO_KLINGON_RETURNS_EXPECTED_DISTANCE()
  INIT_GAME
  SET_ENTERPRISE_POS 4, 4
  SET_KLINGON 1, 7, 8, 200
  ASSERT (DIST_TO_KLINGON(1) = 5.0)
END

DEF TEST_DIST_TO_KLINGON_RETURNS_ZERO_FOR_DEAD_OR_UNUSED_SLOT()
  INIT_GAME
  SET_ENTERPRISE_POS 4, 4
  SET_KLINGON 1, 7, 8, 0
  ASSERT (DIST_TO_KLINGON(1) = 0)
  ASSERT (DIST_TO_KLINGON(2) = 0)
END

DEF TEST_KLINGON_ATTACK_AMOUNT_ROLL_100_MATCHES_BASE_DAMAGE()
  ASSERT (INT(KLINGON_ATTACK_AMOUNT(200, 4, 100)) = 50)
END

DEF TEST_KLINGON_ATTACK_AMOUNT_SCALES_WITH_ROLL_AND_DISTANCE()
  ASSERT (INT(KLINGON_ATTACK_AMOUNT(300, 2, 150)) = 225)
END

DEF TEST_KLINGON_ATTACK_AMOUNT_RETURNS_ZERO_FOR_INVALID_INPUTS()
  ASSERT (INT(KLINGON_ATTACK_AMOUNT(0, 4, 100)) = 0)
  ASSERT (INT(KLINGON_ATTACK_AMOUNT(200, 0, 100)) = 0)
  ASSERT (INT(KLINGON_ATTACK_AMOUNT(200, 4, 0)) = 0)
END

DEF TEST_KLINGON_ATTACK_AMOUNT_FOR_INDEX_AND_ROLL_USES_ENERGY_AND_DISTANCE()
  INIT_GAME
  SET_ENTERPRISE_POS 4, 4
  SET_KLINGON 1, 7, 8, 200
  ASSERT (INT(KLINGON_ATTACK_AMOUNT_FOR_INDEX_AND_ROLL(1, 100)) = 40)
  ASSERT (INT(KLINGON_ATTACK_AMOUNT_FOR_INDEX_AND_ROLL(1, 150)) = 60)
END

DEF TEST_KLINGON_ATTACK_AMOUNT_FOR_INDEX_AND_ROLL_RETURNS_ZERO_FOR_INVALID_OR_DEAD_TARGETS()
  INIT_GAME
  SET_ENTERPRISE_POS 4, 4
  SET_KLINGON 1, 7, 8, 0
  ASSERT (INT(KLINGON_ATTACK_AMOUNT_FOR_INDEX_AND_ROLL(0, 100)) = 0)
  ASSERT (INT(KLINGON_ATTACK_AMOUNT_FOR_INDEX_AND_ROLL(1, 100)) = 0)
  ASSERT (INT(KLINGON_ATTACK_AMOUNT_FOR_INDEX_AND_ROLL(4, 100)) = 0)
END

DEF TEST_KLINGON_ATTACK_AMOUNT_FOR_INDEX_AND_ROLL_RETURNS_ZERO_FOR_UNUSED_NONE_SLOT()
  SET_ENTERPRISE_POS 4, 4
  ASSERT (INT(KLINGON_ATTACK_AMOUNT_FOR_INDEX_AND_ROLL(1, 100)) = 0)
END

DEF TEST_KLINGON_ATTACK_WITH_ROLL_DOES_NOT_DAMAGE_WHEN_DOCKED()
  SETUP_KLINGON_ATTACK_SCENARIO
  LET DOCKED = TRUE
  KLINGON_ATTACK_WITH_ROLL 100
  ASSERT (SHIELDS = 400)
  ASSERT (@K_E[1] = 100)
  ASSERT (@K_E[2] = 80)
END

DEF TEST_KLINGON_ATTACK_WITH_ROLL_SAFE_RETURNS_WHEN_NO_KLINGONS_ARE_PRESENT()
  INIT_GAME
  LET SHIELDS = 400
  LET DOCKED = FALSE
  LET KLINGONS_HERE = 0
  LET KLINGONS_LEFT = 0
  KLINGON_ATTACK_WITH_ROLL 100
  ASSERT (SHIELDS = 400)
END

DEF TEST_KLINGON_ATTACK_WITH_ROLL_IGNORES_DEAD_AND_UNUSED_SLOTS()
  SETUP_KLINGON_ATTACK_SCENARIO
  LET KLINGONS_HERE = 1
  LET @K_E[2] = 0
  KLINGON_ATTACK_WITH_ROLL 100
  ASSERT (INT(SHIELDS) = 350)
  ASSERT (@K_E[2] = 0)
  ASSERT (@K_E[3] = 0)
END

DEF TEST_KLINGON_ATTACK_WITH_ROLL_APPLIES_COMBINED_DAMAGE()
  SETUP_KLINGON_ATTACK_SCENARIO
  KLINGON_ATTACK_WITH_ROLL 100
  ASSERT (INT(SHIELDS) = 330)
  ASSERT (@K_E[1] = 100)
  ASSERT (@K_E[2] = 80)
END

DEF TEST_KLINGON_ATTACK_WITH_ROLL_ALLOW_SHIELD_UNDERFLOW_WITHOUT_CRASH()
  SETUP_KLINGON_ATTACK_SCENARIO
  LET SHIELDS = 30
  KLINGON_ATTACK_WITH_ROLL 100
  ASSERT (INT(SHIELDS) = -40)
  ASSERT_FALSE GAME_OVER
END

DEF TEST_PHASER_HIT_AMOUNT_ROLL_100_MATCHES_BASE_DAMAGE()
  ASSERT (INT(PHASER_HIT_AMOUNT(600, 3, 2, 100)) = 100)
END

DEF TEST_PHASER_HIT_AMOUNT_SCALES_WITH_ROLL_AND_DISTANCE()
  ASSERT (INT(PHASER_HIT_AMOUNT(900, 2, 3, 150)) = 225)
END

DEF TEST_PHASER_HIT_AMOUNT_RETURNS_ZERO_FOR_INVALID_INPUTS()
  ASSERT (INT(PHASER_HIT_AMOUNT(0, 3, 2, 100)) = 0)
  ASSERT (INT(PHASER_HIT_AMOUNT(600, 0, 2, 100)) = 0)
  ASSERT (INT(PHASER_HIT_AMOUNT(600, 3, 0, 100)) = 0)
  ASSERT (INT(PHASER_HIT_AMOUNT(600, 3, 2, 0)) = 0)
END

# kill handling and quadrant/global state synchronization
DEF TEST_DESTROY_KLINGON_UPDATES_SECTOR_COUNTS_AND_SUMMARIES()
  SETUP_DESTROY_KLINGON_SCENARIO
  DESTROY_KLINGON 1
  ASSERT (@SECTOR[6, 7] = 0)
  ASSERT (@SECTOR[2, 3] = 2)
  ASSERT (@K_E[1] = 0)
  ASSERT (@K_E[2] = 90)
  ASSERT (KLINGONS_HERE = 1)
  ASSERT (KLINGONS_LEFT = 6)
  ASSERT (@GALAXY[ENT_QX, ENT_QY] = 114)
  ASSERT (@CHART[ENT_QX, ENT_QY] = 114)
END

DEF TEST_DESTROY_KLINGON_SAFE_RETURNS_FOR_INVALID_OR_DEAD_TARGETS()
  SETUP_DESTROY_KLINGON_SCENARIO
  LET KLINGONS_LEFT = 1
  SET_CURRENT_QUADRANT_SUMMARY 2, 1, 4
  LET @CHART[ENT_QX, ENT_QY] = 214
  LET @K_E[1] = 0
  DESTROY_KLINGON 1
  DESTROY_KLINGON 0
  DESTROY_KLINGON 4
  ASSERT (@SECTOR[6, 7] = 2)
  ASSERT (KLINGONS_HERE = 2)
  ASSERT (KLINGONS_LEFT = 1)
  ASSERT (@GALAXY[ENT_QX, ENT_QY] = 214)
  ASSERT (@CHART[ENT_QX, ENT_QY] = 214)
END

DEF TEST_DESTROY_KLINGON_LAST_ENEMY_DOES_NOT_CRASH()
  SETUP_DESTROY_KLINGON_SCENARIO
  LET KLINGONS_HERE = 1
  LET KLINGONS_LEFT = 1
  SET_CURRENT_QUADRANT_SUMMARY 1, 1, 4
  LET @CHART[ENT_QX, ENT_QY] = 114
  LET @SECTOR[2, 3] = 0
  LET @K_E[2] = 0
  DESTROY_KLINGON 1
  ASSERT (KLINGONS_HERE = 0)
  ASSERT (KLINGONS_LEFT = 0)
  ASSERT (@GALAXY[ENT_QX, ENT_QY] = 14)
  ASSERT (@CHART[ENT_QX, ENT_QY] = 14)
END

DEF TEST_INIT_QUADRANT_CLEARS_UNUSED_KLINGON_SLOTS()
  INIT_GAME
  LET ENT_QX = 4
  LET ENT_QY = 5
  LET ENT_SX = 1
  LET ENT_SY = 1
  SET_CURRENT_QUADRANT_SUMMARY 1, 0, 1
  INIT_QUADRANT
  ASSERT (@K_E[1] = KLINGON_INIT_ENERGY)
  ASSERT (@K_E[2] = 0)
  ASSERT (@K_E[3] = 0)
  ASSERT (COUNT_LIVING_KLINGONS() = 1)
END

# deterministic non-interactive phaser core
DEF TEST_FIRE_PHASERS_IGNORES_NON_POSITIVE_UNITS()
  SETUP_FIRE_PHASERS_SCENARIO
  FIRE_PHASERS_WITH_UNITS_AND_ROLL 0, 100
  ASSERT (ENERGY = 1000)
  ASSERT (@K_E[1] = 150)
  ASSERT (@K_E[2] = 80)
  ASSERT (KLINGONS_HERE = 2)
END

DEF TEST_FIRE_PHASERS_IGNORES_UNITS_ABOVE_AVAILABLE_ENERGY()
  SETUP_FIRE_PHASERS_SCENARIO
  FIRE_PHASERS_WITH_UNITS_AND_ROLL 1001, 100
  ASSERT (ENERGY = 1000)
  ASSERT (@K_E[1] = 150)
  ASSERT (@K_E[2] = 80)
  ASSERT (KLINGONS_HERE = 2)
END

DEF TEST_FIRE_PHASERS_APPLIES_HITS_TO_LIVING_KLINGONS_ONLY()
  SETUP_FIRE_PHASERS_SCENARIO
  FIRE_PHASERS_WITH_UNITS_AND_ROLL 600, 100
  ASSERT (ENERGY = 400)
  ASSERT (INT(@K_E[1]) = 50)
  ASSERT (INT(@K_E[2]) = 0)
  ASSERT (@K_E[3] = 0)
  ASSERT (KLINGONS_HERE = 1)
  ASSERT (KLINGONS_LEFT = 6)
  ASSERT (@SECTOR[4, 1] = 2)
  ASSERT (@SECTOR[1, 4] = 0)
  ASSERT (@GALAXY[ENT_QX, ENT_QY] = 114)
  ASSERT (@CHART[ENT_QX, ENT_QY] = 114)
END

DEF TEST_FIRE_PHASERS_SAFE_RETURNS_WHEN_NO_KLINGONS_ARE_PRESENT()
  INIT_GAME
  LET ENERGY = 1000
  LET KLINGONS_HERE = 0
  LET KLINGONS_LEFT = 0
  FIRE_PHASERS_WITH_UNITS_AND_ROLL 250, 100
  ASSERT (ENERGY = 1000)
  ASSERT (KLINGONS_HERE = 0)
  ASSERT (KLINGONS_LEFT = 0)
END

DEF TEST_FIRE_PHASERS_WITH_ONE_KLINGON_IGNORES_UNUSED_SLOTS()
  INIT_GAME
  LET ENT_QX = 4
  LET ENT_QY = 5
  LET ENT_SX = 1
  LET ENT_SY = 1
  LET ENERGY = 1000
  LET KLINGONS_LEFT = 1
  SET_CURRENT_QUADRANT_SUMMARY 1, 0, 1
  INIT_QUADRANT
  FIRE_PHASERS_WITH_UNITS_AND_ROLL 300, 100
  ASSERT (ENERGY = 700)
  ASSERT (@K_E[2] = 0)
  ASSERT (@K_E[3] = 0)
  ASSERT (COUNT_LIVING_KLINGONS() <= 1)
END

# damage gate and command boundary behavior
DEF TEST_INIT_GAME_INITIALIZES_DAMAGE_SLOTS()
  INIT_GAME
  ASSERT_FALSE PHASER_CONTROL_DISABLED()
  ASSERT_FALSE PHASER_COMPUTER_FAILURE_ACTIVE()
  ASSERT (@DAMAGE[1] = 0)
  ASSERT (@DAMAGE[8] = 0)
END

DEF TEST_PHASER_CONTROL_DISABLED_TRACKS_DAMAGE_SLOT_4()
  INIT_GAME
  LET @DAMAGE[4] = 0
  ASSERT_FALSE PHASER_CONTROL_DISABLED()
  LET @DAMAGE[4] = -1
  ASSERT PHASER_CONTROL_DISABLED()
END

DEF TEST_PHASER_COMPUTER_FAILURE_ACTIVE_TRACKS_DAMAGE_SLOT_7()
  INIT_GAME
  LET @DAMAGE[7] = 0
  ASSERT_FALSE PHASER_COMPUTER_FAILURE_ACTIVE()
  LET @DAMAGE[7] = -1
  ASSERT PHASER_COMPUTER_FAILURE_ACTIVE()
END

DEF TEST_TRY_FIRE_PHASERS_UNITS_IGNORES_NON_POSITIVE_UNITS()
  SETUP_FIRE_PHASERS_SCENARIO
  ASSERT_FALSE TRY_FIRE_PHASERS_UNITS(0)
  ASSERT (ENERGY = 1000)
  ASSERT (@K_E[1] = 150)
  ASSERT (@K_E[2] = 80)
END

DEF TEST_TRY_FIRE_PHASERS_UNITS_IGNORES_UNITS_ABOVE_AVAILABLE_ENERGY()
  SETUP_FIRE_PHASERS_SCENARIO
  ASSERT_FALSE TRY_FIRE_PHASERS_UNITS(1001)
  ASSERT (ENERGY = 1000)
  ASSERT (@K_E[1] = 150)
  ASSERT (@K_E[2] = 80)
END

DEF TEST_TRY_FIRE_PHASERS_UNITS_DISPATCHES_TO_CORE_ON_VALID_INPUT()
  SETUP_FIRE_PHASERS_SCENARIO
  ASSERT TRY_FIRE_PHASERS_UNITS(600)
  ASSERT (ENERGY = 400)
  ASSERT (KLINGONS_HERE <= 2)
END

DEF TEST_PHASER_CONTROL_SAFE_RETURNS_WHEN_NO_KLINGONS_ARE_PRESENT()
  INIT_GAME
  LET ENERGY = 1000
  LET KLINGONS_HERE = 0
  LET KLINGONS_LEFT = 0
  PHASER_CONTROL
  ASSERT (ENERGY = 1000)
  ASSERT (KLINGONS_HERE = 0)
  ASSERT (KLINGONS_LEFT = 0)
END

DEF TEST_PHASER_CONTROL_DAMAGE_GATE_PREVENTS_FIRING()
  SETUP_FIRE_PHASERS_SCENARIO
  LET @DAMAGE[4] = -1
  PHASER_CONTROL
  ASSERT (ENERGY = 1000)
  ASSERT (@K_E[1] = 150)
  ASSERT (@K_E[2] = 80)
  ASSERT (KLINGONS_HERE = 2)
END

