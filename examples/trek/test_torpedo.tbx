USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "combat.tbx"
USE "../../lib/tests/helper.tbx"

DEF SET_KLINGON_AT(I, SX, SY, E)
  LET @K_X[I] = SX
  LET @K_Y[I] = SY
  LET @K_E[I] = E
END

DEF SET_CURRENT_QUADRANT_SUMMARY(KLINGON_COUNT, BASE_COUNT, STAR_COUNT)
  LET @GALAXY[ENT_QX, ENT_QY] = ENCODE_QUADRANT_SUMMARY(KLINGON_COUNT, BASE_COUNT, STAR_COUNT)
  LET @CHART[ENT_QX, ENT_QY] = ENCODE_QUADRANT_SUMMARY(KLINGON_COUNT, BASE_COUNT, STAR_COUNT)
END

DEF CLEAR_OUTPUT_BUFFER()
  VAR DISCARDED = GET_OUTPUT()
END

DEF SETUP_TORPEDO_SCENARIO()
  INIT_GAME
  LET ENT_QX = 4
  LET ENT_QY = 5
  LET ENT_SX = 4
  LET ENT_SY = 4
  CLEAR_SECTOR
  LET @SECTOR[ENT_SX, ENT_SY] = 1
  LET TORPEDOES = 5
  LET BASES_LEFT = 2
  LET KLINGONS_LEFT = 1
  LET KLINGONS_HERE = 1
  LET BASES_HERE = 0
  LET STARS_HERE = 0
  SET_CURRENT_QUADRANT_SUMMARY 1, 0, 0
  SET_KLINGON_AT 1, 8, 8, 200
  SET_KLINGON_AT 2, 0, 0, 0
  SET_KLINGON_AT 3, 0, 0, 0
  LET @SECTOR[8, 8] = 2
END

DEF TEST_TORPEDO_SAFE_RETURNS_WHEN_NO_KLINGONS_ARE_PRESENT()
  INIT_GAME
  LET TORPEDOES = 5
  LET KLINGONS_HERE = 0
  LET KLINGONS_LEFT = 0
  CLEAR_OUTPUT_BUFFER
  ASSERT_FALSE TRY_FIRE_TORPEDO_WITH_COURSE(1)
  ASSERT_OUTPUT "SHORT RANGE SENSORS REPORT NO KLINGONS IN THIS QUADRANT\n"
  ASSERT (TORPEDOES = 5)
END

DEF TEST_TORPEDO_REJECTS_DISABLED_PHOTON_TUBES()
  SETUP_TORPEDO_SCENARIO
  SET_DEVICE_DAMAGE DAMAGE_SLOT_PHOTON_TUBES(), -1
  CLEAR_OUTPUT_BUFFER
  ASSERT_FALSE TRY_FIRE_TORPEDO_WITH_COURSE(1)
  ASSERT_OUTPUT "PHOTON TUBES ARE NOT OPERATIONAL\n"
  ASSERT (TORPEDOES = 5)
END

DEF TEST_TORPEDO_REJECTS_EMPTY_INVENTORY()
  SETUP_TORPEDO_SCENARIO
  LET TORPEDOES = 0
  CLEAR_OUTPUT_BUFFER
  ASSERT_FALSE TRY_FIRE_TORPEDO_WITH_COURSE(1)
  ASSERT_OUTPUT "ALL PHOTON TORPEDOES EXPENDED\n"
  ASSERT (TORPEDOES = 0)
END

DEF TEST_TORPEDO_CONTROL_NO_KLINGONS_DOES_NOT_PROMPT()
  INIT_GAME
  LET TORPEDOES = 5
  LET KLINGONS_HERE = 0
  LET KLINGONS_LEFT = 0
  CLEAR_OUTPUT_BUFFER
  TORPEDO_CONTROL
  ASSERT_OUTPUT "SHORT RANGE SENSORS REPORT NO KLINGONS IN THIS QUADRANT\n"
END

DEF TEST_TORPEDO_CONTROL_DISABLED_TUBES_DOES_NOT_PROMPT()
  SETUP_TORPEDO_SCENARIO
  SET_DEVICE_DAMAGE DAMAGE_SLOT_PHOTON_TUBES(), -1
  CLEAR_OUTPUT_BUFFER
  TORPEDO_CONTROL
  ASSERT_OUTPUT "PHOTON TUBES ARE NOT OPERATIONAL\n"
  ASSERT (TORPEDOES = 5)
END

DEF TEST_TORPEDO_CONTROL_EMPTY_INVENTORY_DOES_NOT_PROMPT()
  SETUP_TORPEDO_SCENARIO
  LET TORPEDOES = 0
  CLEAR_OUTPUT_BUFFER
  TORPEDO_CONTROL
  ASSERT_OUTPUT "ALL PHOTON TORPEDOES EXPENDED\n"
  ASSERT (TORPEDOES = 0)
END

DEF TEST_TORPEDO_COURSE_ZERO_IS_A_SILENT_NOOP()
  SETUP_TORPEDO_SCENARIO
  LET SHIELDS = 400
  CLEAR_OUTPUT_BUFFER
  ASSERT_FALSE TRY_FIRE_TORPEDO_WITH_COURSE_AND_ROLL(0, 100)
  ASSERT_OUTPUT ""
  ASSERT (TORPEDOES = 5)
  ASSERT (SHIELDS = 400)
END

DEF TEST_TORPEDO_REJECTS_INVALID_COURSE()
  SETUP_TORPEDO_SCENARIO
  LET SHIELDS = 400
  CLEAR_OUTPUT_BUFFER
  ASSERT_FALSE TRY_FIRE_TORPEDO_WITH_COURSE_AND_ROLL(9, 100)
  ASSERT_OUTPUT "INVALID COURSE. MUST BE 1 <= COURSE < 9.\n"
  ASSERT (TORPEDOES = 5)
  ASSERT (SHIELDS = 400)
END

DEF TEST_TORPEDO_MISS_RETALIATES_AFTER_VALID_SHOT()
  SETUP_TORPEDO_SCENARIO
  LET SHIELDS = 400
  CLEAR_OUTPUT_BUFFER
  ASSERT TRY_FIRE_TORPEDO_WITH_COURSE_AND_ROLL(1, 100)
  ASSERT_OUTPUT "TORPEDO TRACK:\n5,4\n6,4\n7,4\n8,4\nTORPEDO MISSED\n35 UNIT HIT ON ENTERPRISE FROM SECTOR 8,8 SHIELDS LEFT 364\n"
  ASSERT (TORPEDOES = 4)
  ASSERT (KLINGONS_HERE = 1)
  ASSERT (KLINGONS_LEFT = 1)
  ASSERT (SHIELDS = 364.6446609406726)
END

DEF TEST_TORPEDO_DESTROYS_KLINGON_AND_RETALIATES_WHEN_OTHERS_SURVIVE()
  SETUP_TORPEDO_SCENARIO
  SET_KLINGON_AT 1, 6, 4, 200
  LET @SECTOR[6, 4] = 2
  SET_KLINGON_AT 2, 8, 8, 300
  LET KLINGONS_HERE = 2
  LET KLINGONS_LEFT = 2
  SET_CURRENT_QUADRANT_SUMMARY 2, 0, 0
  LET SHIELDS = 500
  CLEAR_OUTPUT_BUFFER
  ASSERT TRY_FIRE_TORPEDO_WITH_COURSE_AND_ROLL(1, 100)
  ASSERT_OUTPUT "TORPEDO TRACK:\n5,4\n6,4\n*** KLINGON DESTROYED ***\n53 UNIT HIT ON ENTERPRISE FROM SECTOR 8,8 SHIELDS LEFT 446\n"
  ASSERT (TORPEDOES = 4)
  ASSERT (@SECTOR[6, 4] = 0)
  ASSERT (@K_E[1] = 0)
  ASSERT (KLINGONS_HERE = 1)
  ASSERT (KLINGONS_LEFT = 1)
  ASSERT (@GALAXY[ENT_QX, ENT_QY] = 100)
  ASSERT (@CHART[ENT_QX, ENT_QY] = 100)
  ASSERT (SHIELDS = 446.96699141100896)
END

DEF TEST_TORPEDO_DOES_NOT_RETALIATE_AFTER_DESTROYING_LAST_KLINGON()
  SETUP_TORPEDO_SCENARIO
  SET_KLINGON_AT 1, 6, 4, 200
  LET @SECTOR[6, 4] = 2
  LET SHIELDS = 400
  CLEAR_OUTPUT_BUFFER
  ASSERT TRY_FIRE_TORPEDO_WITH_COURSE_AND_ROLL(1, 100)
  ASSERT_OUTPUT "TORPEDO TRACK:\n5,4\n6,4\n*** KLINGON DESTROYED ***\n"
  ASSERT (TORPEDOES = 4)
  ASSERT (KLINGONS_HERE = 0)
  ASSERT (KLINGONS_LEFT = 0)
  ASSERT (SHIELDS = 400)
END

DEF TEST_TORPEDO_HITTING_STAR_LEAVES_STATE_UNCHANGED()
  SETUP_TORPEDO_SCENARIO
  LET STARS_HERE = 1
  SET_CURRENT_QUADRANT_SUMMARY 1, 0, 1
  LET @SECTOR[6, 4] = 4
  LET SHIELDS = 400
  CLEAR_OUTPUT_BUFFER
  ASSERT TRY_FIRE_TORPEDO_WITH_COURSE_AND_ROLL(1, 100)
  ASSERT_OUTPUT "TORPEDO TRACK:\n5,4\n6,4\nYOU CAN'T DESTROY STARS SILLY\n35 UNIT HIT ON ENTERPRISE FROM SECTOR 8,8 SHIELDS LEFT 364\n"
  ASSERT (TORPEDOES = 4)
  ASSERT (@SECTOR[6, 4] = 4)
  ASSERT (STARS_HERE = 1)
  ASSERT (@GALAXY[ENT_QX, ENT_QY] = 101)
  ASSERT (SHIELDS = 364.6446609406726)
END

DEF TEST_TORPEDO_DESTROYS_STARBASE_AND_UPDATES_SUMMARY()
  SETUP_TORPEDO_SCENARIO
  LET BASES_HERE = 1
  SET_CURRENT_QUADRANT_SUMMARY 1, 1, 0
  LET @SECTOR[6, 4] = 3
  LET SHIELDS = 400
  CLEAR_OUTPUT_BUFFER
  ASSERT TRY_FIRE_TORPEDO_WITH_COURSE_AND_ROLL(1, 100)
  ASSERT_OUTPUT "TORPEDO TRACK:\n5,4\n6,4\n*** STAR BASE DESTROYED ***  .......CONGRATULATIONS\n35 UNIT HIT ON ENTERPRISE FROM SECTOR 8,8 SHIELDS LEFT 364\n"
  ASSERT (TORPEDOES = 4)
  ASSERT (@SECTOR[6, 4] = 0)
  ASSERT (BASES_HERE = 0)
  ASSERT (BASES_LEFT = 1)
  ASSERT (KLINGONS_HERE = 1)
  ASSERT (@GALAXY[ENT_QX, ENT_QY] = 100)
  ASSERT (@CHART[ENT_QX, ENT_QY] = 100)
  ASSERT (SHIELDS = 364.6446609406726)
END

DEF TEST_TORPEDO_DOCKED_RETALIATION_IS_BLOCKED_BY_STARBASE_PROTECTION()
  SETUP_TORPEDO_SCENARIO
  LET DOCKED = TRUE
  LET SHIELDS = 400
  CLEAR_OUTPUT_BUFFER
  ASSERT TRY_FIRE_TORPEDO_WITH_COURSE_AND_ROLL(1, 100)
  ASSERT_OUTPUT "TORPEDO TRACK:\n5,4\n6,4\n7,4\n8,4\nTORPEDO MISSED\nSTAR BASE SHIELDS PROTECT THE ENTERPRISE\n"
  ASSERT (TORPEDOES = 4)
  ASSERT (SHIELDS = 400)
END

TEST_TORPEDO_SAFE_RETURNS_WHEN_NO_KLINGONS_ARE_PRESENT
TEST_TORPEDO_REJECTS_DISABLED_PHOTON_TUBES
TEST_TORPEDO_REJECTS_EMPTY_INVENTORY
TEST_TORPEDO_CONTROL_NO_KLINGONS_DOES_NOT_PROMPT
TEST_TORPEDO_CONTROL_DISABLED_TUBES_DOES_NOT_PROMPT
TEST_TORPEDO_CONTROL_EMPTY_INVENTORY_DOES_NOT_PROMPT
TEST_TORPEDO_COURSE_ZERO_IS_A_SILENT_NOOP
TEST_TORPEDO_REJECTS_INVALID_COURSE
TEST_TORPEDO_MISS_RETALIATES_AFTER_VALID_SHOT
TEST_TORPEDO_DESTROYS_KLINGON_AND_RETALIATES_WHEN_OTHERS_SURVIVE
TEST_TORPEDO_DOES_NOT_RETALIATE_AFTER_DESTROYING_LAST_KLINGON
TEST_TORPEDO_HITTING_STAR_LEAVES_STATE_UNCHANGED
TEST_TORPEDO_DESTROYS_STARBASE_AND_UPDATES_SUMMARY
TEST_TORPEDO_DOCKED_RETALIATION_IS_BLOCKED_BY_STARBASE_PROTECTION
