USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "scan.tbx"
USE "combat.tbx"
USE "nav.tbx"
USE "../../lib/tests/helper.tbx"

DEF SET_ENTERPRISE_AT(QX, QY, SX, SY)
  LET ENT_QX = QX
  LET ENT_QY = QY
  CLEAR_SECTOR
  LET ENT_SX = SX
  LET ENT_SY = SY
  LET @SECTOR[ENT_SX, ENT_SY] = 1
END

DEF SET_KLINGON_AT(I, SX, SY, E)
  LET @K_X[I] = SX
  LET @K_Y[I] = SY
  LET @K_E[I] = E
  LET @SECTOR[SX, SY] = 2
END

DEF TEST_NAVIGATION_RETALIATES_AFTER_VALID_SAME_QUADRANT_MOVE()
  INIT_GAME
  SET_ENTERPRISE_AT 4, 4, 4, 4
  LET SHIELDS = 400
  LET DOCKED = FALSE
  LET KLINGONS_HERE = 1
  LET KLINGONS_LEFT = 1
  SET_KLINGON_AT 1, 7, 4, 200
  RUN_NAVIGATION_WITH_ROLL 1, 0.2, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT())
  ASSERT (ENT_SX = 5)
  ASSERT (SHIELDS = 300)
END

DEF TEST_NAVIGATION_DOES_NOT_RETALIATE_AFTER_NO_OP_MOVE()
  INIT_GAME
  SET_ENTERPRISE_AT 4, 4, 4, 4
  LET SHIELDS = 400
  LET DOCKED = FALSE
  LET KLINGONS_HERE = 1
  LET KLINGONS_LEFT = 1
  SET_KLINGON_AT 1, 7, 4, 200
  RUN_NAVIGATION_WITH_ROLL 1, 0.1, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_NONE())
  ASSERT (NAV_STEPS_COMPLETED = 0)
  ASSERT (ENT_SX = 4)
  ASSERT (SHIELDS = 400)
END

DEF TEST_NAVIGATION_DOES_NOT_RETALIATE_AFTER_BLOCKED_PARTIAL_MOVE()
  INIT_GAME
  SET_ENTERPRISE_AT 4, 4, 4, 4
  LET SHIELDS = 400
  LET DOCKED = FALSE
  LET KLINGONS_HERE = 1
  LET KLINGONS_LEFT = 1
  SET_KLINGON_AT 1, 7, 4, 200
  LET @SECTOR[6, 4] = 4
  RUN_NAVIGATION_WITH_ROLL 1, 0.375, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_BLOCKED())
  ASSERT (NAV_STEPS_COMPLETED = 1)
  ASSERT (ENT_SX = 5)
  ASSERT (SHIELDS = 400)
END

DEF TEST_NAVIGATION_SAFE_NOOPS_WHEN_CURRENT_QUADRANT_HAS_NO_KLINGONS()
  INIT_GAME
  SET_ENTERPRISE_AT 4, 4, 4, 4
  LET SHIELDS = 400
  LET DOCKED = FALSE
  LET KLINGONS_HERE = 0
  LET KLINGONS_LEFT = 0
  RUN_NAVIGATION_WITH_ROLL 1, 0.2, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT())
  ASSERT (ENT_SX = 5)
  ASSERT (SHIELDS = 400)
END

DEF TEST_NAVIGATION_CROSSING_USES_NEW_QUADRANT_KLINGON_STATE()
  INIT_GAME
  LET @GALAXY[4, 4] = 100
  LET @GALAXY[5, 4] = 0
  SET_ENTERPRISE_AT 4, 4, 8, 4
  LET SHIELDS = 400
  LET DOCKED = FALSE
  LET KLINGONS_HERE = 1
  LET KLINGONS_LEFT = 1
  SET_KLINGON_AT 1, 7, 4, 200
  RUN_NAVIGATION_WITH_ROLL 1, 0.2, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_QUADRANT_CROSSING())
  ASSERT (ENT_QX = 5)
  ASSERT (KLINGONS_HERE = 0)
  ASSERT (SHIELDS = 400)
END

DEF TEST_NAVIGATION_CROSSING_RETALIATES_IN_NEW_KLINGON_QUADRANT()
  INIT_GAME
  LET @GALAXY[4, 4] = 0
  LET @GALAXY[5, 4] = 100
  SET_ENTERPRISE_AT 4, 4, 8, 4
  LET SHIELDS = 400
  LET DOCKED = FALSE
  LET KLINGONS_HERE = 0
  LET KLINGONS_LEFT = 1
  RUN_NAVIGATION_WITH_ROLL 1, 0.2, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_QUADRANT_CROSSING())
  ASSERT (ENT_QX = 5)
  ASSERT (KLINGONS_HERE = 1)
  ASSERT (SHIELDS < 400)
END

TEST_NAVIGATION_RETALIATES_AFTER_VALID_SAME_QUADRANT_MOVE
TEST_NAVIGATION_DOES_NOT_RETALIATE_AFTER_NO_OP_MOVE
TEST_NAVIGATION_DOES_NOT_RETALIATE_AFTER_BLOCKED_PARTIAL_MOVE
TEST_NAVIGATION_SAFE_NOOPS_WHEN_CURRENT_QUADRANT_HAS_NO_KLINGONS
TEST_NAVIGATION_CROSSING_USES_NEW_QUADRANT_KLINGON_STATE
TEST_NAVIGATION_CROSSING_RETALIATES_IN_NEW_KLINGON_QUADRANT
