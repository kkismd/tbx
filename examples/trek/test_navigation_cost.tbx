# trek/test_navigation_cost.tbx - navigation energy cost tests

USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "scan.tbx"
USE "nav.tbx"
USE "../../lib/tests/helper.tbx"

DEF SET_POS(QX, QY, SX, SY)
  LET ENT_QX = QX
  LET ENT_QY = QY
  CLEAR_SECTOR
  LET ENT_SX = SX
  LET ENT_SY = SY
  LET @SECTOR[ENT_SX, ENT_SY] = 1
END

DEF TEST_APPLY_NAV_ENERGY_COST_STEP_1()
  INIT_GAME
  LET ENERGY = 1000
  APPLY_NAV_ENERGY_COST 1
  ASSERT (ENERGY = 1004)
END

DEF TEST_APPLY_NAV_ENERGY_COST_STEP_8()
  INIT_GAME
  LET ENERGY = 1000
  APPLY_NAV_ENERGY_COST 8
  ASSERT (ENERGY = 997)
END

DEF TEST_STARDATE_COST_SAME_QUADRANT_WARP_LT_1()
  INIT_GAME
  LET STARDATE = 1000
  LET NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT()
  APPLY_NAV_STARDATE_COST 0.5
  ASSERT (STARDATE = 1000)
END

DEF TEST_STARDATE_COST_SAME_QUADRANT_WARP_GE_1()
  INIT_GAME
  LET STARDATE = 1000
  LET NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT()
  APPLY_NAV_STARDATE_COST 1.0
  ASSERT (STARDATE = 1001)
END

DEF TEST_STARDATE_COST_BLOCKED_FOLLOWS_SAME_QUADRANT_PATH()
  INIT_GAME
  LET STARDATE = 1000
  LET NAV_MOVE_RESULT = NAV_RESULT_BLOCKED()
  APPLY_NAV_STARDATE_COST 0.5
  ASSERT (STARDATE = 1000)
  APPLY_NAV_STARDATE_COST 1.0
  ASSERT (STARDATE = 1001)
END

DEF TEST_STARDATE_COST_GALAXY_EDGE_FOLLOWS_SAME_QUADRANT_PATH()
  INIT_GAME
  LET STARDATE = 1000
  LET NAV_MOVE_RESULT = NAV_RESULT_GALAXY_EDGE()
  APPLY_NAV_STARDATE_COST 0.5
  ASSERT (STARDATE = 1000)
  APPLY_NAV_STARDATE_COST 1.0
  ASSERT (STARDATE = 1001)
END

DEF TEST_STARDATE_COST_QUADRANT_CROSSING_WARP_LT_1()
  INIT_GAME
  LET STARDATE = 1000
  LET NAV_MOVE_RESULT = NAV_RESULT_QUADRANT_CROSSING()
  APPLY_NAV_STARDATE_COST 0.5
  ASSERT (STARDATE = 1001)
END

DEF TEST_FRACTIONAL_WARP_COST_AND_MOVE()
  INIT_GAME
  LET STARDATE = 1000
  SET_POS 4, 4, 4, 4
  RUN_NAVIGATION 1, 0.2
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT())
  ASSERT (NAV_STEPS_REQUESTED = 1)
  ASSERT (NAV_STEPS_COMPLETED = 1)
  ASSERT (ENERGY = 3004)
  ASSERT (STARDATE = 1000)
  ASSERT (ENT_SX = 5)
  ASSERT (ENT_SY = 4)
END

DEF TEST_WARP_ONE_USES_EIGHT_REQUESTED_STEPS()
  INIT_GAME
  LET STARDATE = 1000
  SET_POS 4, 4, 4, 4
  LET @SECTOR[5, 4] = 4
  RUN_NAVIGATION 1, 1.0
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_BLOCKED())
  ASSERT (NAV_STEPS_REQUESTED = 8)
  ASSERT (NAV_STEPS_COMPLETED = 0)
  ASSERT (ENERGY = 2997)
  ASSERT (STARDATE = 1001)
END

DEF TEST_BLOCKED_COST_USES_REQUESTED_STEPS()
  INIT_GAME
  LET STARDATE = 1000
  SET_POS 4, 4, 4, 4
  LET @SECTOR[6, 4] = 4
  RUN_NAVIGATION 1, 0.375
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_BLOCKED())
  ASSERT (NAV_STEPS_REQUESTED = 3)
  ASSERT (NAV_STEPS_COMPLETED = 1)
  ASSERT (ENERGY = 3002)
  ASSERT (STARDATE = 1000)
  ASSERT (ENT_SX = 5)
  ASSERT (ENT_SY = 4)
END

DEF TEST_GALAXY_EDGE_COST_USES_REQUESTED_STEPS()
  INIT_GAME
  LET STARDATE = 1000
  SET_POS 8, 4, 4, 4
  RUN_NAVIGATION 1, 1.0
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_GALAXY_EDGE())
  ASSERT (NAV_STEPS_REQUESTED = 8)
  ASSERT (NAV_STEPS_COMPLETED = 4)
  ASSERT (ENERGY = 2997)
  ASSERT (STARDATE = 1001)
  ASSERT (ENT_QX = 8)
  ASSERT (ENT_SX = 8)
END

DEF TEST_QUADRANT_CROSSING_COST_USES_REQUESTED_STEPS()
  INIT_GAME
  LET STARDATE = 1000
  SET_POS 4, 4, 7, 4
  RUN_NAVIGATION 1, 0.375
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_QUADRANT_CROSSING())
  ASSERT (NAV_STEPS_REQUESTED = 3)
  ASSERT (NAV_STEPS_COMPLETED = 2)
  ASSERT (ENERGY = 3002)
  ASSERT (STARDATE = 1001)
  ASSERT (ENT_QX = 5)
  ASSERT (ENT_SX = 1)
END

DEF TEST_DECIMAL_COURSE_COST_AND_MOVE()
  INIT_GAME
  LET STARDATE = 1000
  SET_POS 4, 4, 4, 4
  RUN_NAVIGATION 1.5, 0.25
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT())
  ASSERT (NAV_STEPS_REQUESTED = 2)
  ASSERT (NAV_STEPS_COMPLETED = 2)
  ASSERT (ENERGY = 3003)
  ASSERT (STARDATE = 1000)
  ASSERT (ENT_SX = 6)
  ASSERT (ENT_SY = 3)
END

DEF TEST_DEADLINE_TODO_PATH_DOES_NOT_END_GAME()
  INIT_GAME
  LET START_STARDATE = 1000
  LET MISSION_DAYS = 30
  LET STARDATE = 1031
  LET GAME_OVER = FALSE
  CHECK_MISSION_DEADLINE
  ASSERT_FALSE GAME_OVER
END

DEF TEST_NAVIGATION_WITH_NO_ENERGY_AND_SHIELDS_RETURNS_WITHOUT_MOVEMENT()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  LET ENERGY = 0
  LET SHIELDS = 100
  RUN_NAVIGATION 1, 1.0
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_NONE())
  ASSERT (NAV_STEPS_REQUESTED = 0)
  ASSERT (NAV_STEPS_COMPLETED = 0)
  ASSERT (ENT_SX = 4)
  ASSERT (ENT_SY = 4)
  ASSERT (ENERGY = 0)
  ASSERT_FALSE GAME_OVER
END

DEF TEST_NAVIGATION_WITH_NO_ENERGY_AND_NO_SHIELDS_RETURNS_WITHOUT_MOVEMENT()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  LET ENERGY = -1
  LET SHIELDS = 0
  RUN_NAVIGATION 1, 1.0
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_NONE())
  ASSERT (NAV_STEPS_REQUESTED = 0)
  ASSERT (NAV_STEPS_COMPLETED = 0)
  ASSERT (ENT_SX = 4)
  ASSERT (ENT_SY = 4)
  ASSERT (ENERGY = -1)
  ASSERT_FALSE GAME_OVER
END

DEF TEST_NAVIGATION_ENERGY_DEPLETED_AFTER_COST_DOES_NOT_END_GAME()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  LET ENERGY = 2
  LET SHIELDS = 50
  RUN_NAVIGATION 1, 1.0
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_QUADRANT_CROSSING())
  ASSERT (NAV_STEPS_REQUESTED = 8)
  ASSERT (ENERGY = -1)
  ASSERT_FALSE GAME_OVER
END

TEST_APPLY_NAV_ENERGY_COST_STEP_1
TEST_APPLY_NAV_ENERGY_COST_STEP_8
TEST_STARDATE_COST_SAME_QUADRANT_WARP_LT_1
TEST_STARDATE_COST_SAME_QUADRANT_WARP_GE_1
TEST_STARDATE_COST_BLOCKED_FOLLOWS_SAME_QUADRANT_PATH
TEST_STARDATE_COST_GALAXY_EDGE_FOLLOWS_SAME_QUADRANT_PATH
TEST_STARDATE_COST_QUADRANT_CROSSING_WARP_LT_1
TEST_FRACTIONAL_WARP_COST_AND_MOVE
TEST_WARP_ONE_USES_EIGHT_REQUESTED_STEPS
TEST_BLOCKED_COST_USES_REQUESTED_STEPS
TEST_GALAXY_EDGE_COST_USES_REQUESTED_STEPS
TEST_QUADRANT_CROSSING_COST_USES_REQUESTED_STEPS
TEST_DECIMAL_COURSE_COST_AND_MOVE
TEST_DEADLINE_TODO_PATH_DOES_NOT_END_GAME
TEST_NAVIGATION_WITH_NO_ENERGY_AND_SHIELDS_RETURNS_WITHOUT_MOVEMENT
TEST_NAVIGATION_WITH_NO_ENERGY_AND_NO_SHIELDS_RETURNS_WITHOUT_MOVEMENT
TEST_NAVIGATION_ENERGY_DEPLETED_AFTER_COST_DOES_NOT_END_GAME
