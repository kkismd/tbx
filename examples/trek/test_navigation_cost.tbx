# trek/test_navigation_cost.tbx - navigation energy cost tests

USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "scan.tbx"
USE "combat.tbx"
USE "nav.tbx"
USE "../../lib/tests/helper.tbx"

DEF SET_POS(QX, QY, SX, SY)
  LET ENT_QX = QX
  LET ENT_QY = QY
  CLEAR_SECTOR
  LET ENT_SX = SX
  LET ENT_SY = SY
  LET @SECTOR[ENT_SX, ENT_SY] = 1
END

DEF CLEAR_OUTPUT_BUFFER()
  VAR DISCARDED = GET_OUTPUT()
END

DEF TEST_APPLY_NAV_ENERGY_COST_STEP_1()
  INIT_GAME
  LET ENERGY = 1000
  APPLY_NAV_ENERGY_COST 1
  ASSERT (ENERGY = 1004)
END

DEF TEST_APPLY_NAV_ENERGY_COST_STEP_8()
  INIT_GAME
  LET ENERGY = 1000
  APPLY_NAV_ENERGY_COST 8
  ASSERT (ENERGY = 997)
END

DEF TEST_STARDATE_COST_SAME_QUADRANT_WARP_LT_1()
  INIT_GAME
  LET STARDATE = 1000
  LET NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT()
  APPLY_NAV_STARDATE_COST 0.5
  ASSERT (STARDATE = 1000)
END

DEF TEST_STARDATE_COST_SAME_QUADRANT_WARP_GE_1()
  INIT_GAME
  LET STARDATE = 1000
  LET NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT()
  APPLY_NAV_STARDATE_COST 1.0
  ASSERT (STARDATE = 1001)
END

DEF TEST_STARDATE_COST_BLOCKED_FOLLOWS_SAME_QUADRANT_PATH()
  INIT_GAME
  LET STARDATE = 1000
  LET NAV_MOVE_RESULT = NAV_RESULT_BLOCKED()
  APPLY_NAV_STARDATE_COST 0.5
  ASSERT (STARDATE = 1000)
  APPLY_NAV_STARDATE_COST 1.0
  ASSERT (STARDATE = 1001)
END

DEF TEST_STARDATE_COST_GALAXY_EDGE_FOLLOWS_SAME_QUADRANT_PATH()
  INIT_GAME
  LET STARDATE = 1000
  LET NAV_MOVE_RESULT = NAV_RESULT_GALAXY_EDGE()
  APPLY_NAV_STARDATE_COST 0.5
  ASSERT (STARDATE = 1000)
  APPLY_NAV_STARDATE_COST 1.0
  ASSERT (STARDATE = 1001)
END

DEF TEST_STARDATE_COST_QUADRANT_CROSSING_WARP_LT_1()
  INIT_GAME
  LET STARDATE = 1000
  LET NAV_MOVE_RESULT = NAV_RESULT_QUADRANT_CROSSING()
  APPLY_NAV_STARDATE_COST 0.5
  ASSERT (STARDATE = 1001)
END

DEF TEST_FRACTIONAL_WARP_COST_AND_MOVE()
  INIT_GAME
  LET STARDATE = 1000
  SET_POS 4, 4, 4, 4
  RUN_NAVIGATION 1, 0.2
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT())
  ASSERT (NAV_STEPS_REQUESTED = 1)
  ASSERT (NAV_STEPS_COMPLETED = 1)
  ASSERT (ENERGY = 3004)
  ASSERT (STARDATE = 1000)
  ASSERT (ENT_SX = 5)
  ASSERT (ENT_SY = 4)
END

DEF TEST_WARP_ONE_USES_EIGHT_REQUESTED_STEPS()
  INIT_GAME
  LET STARDATE = 1000
  SET_POS 4, 4, 4, 4
  LET @SECTOR[5, 4] = 4
  RUN_NAVIGATION 1, 1.0
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_BLOCKED())
  ASSERT (NAV_STEPS_REQUESTED = 8)
  ASSERT (NAV_STEPS_COMPLETED = 0)
  ASSERT (ENERGY = 2997)
  ASSERT (STARDATE = 1001)
END

DEF TEST_BLOCKED_COST_USES_REQUESTED_STEPS()
  INIT_GAME
  LET STARDATE = 1000
  SET_POS 4, 4, 4, 4
  LET @SECTOR[6, 4] = 4
  RUN_NAVIGATION 1, 0.375
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_BLOCKED())
  ASSERT (NAV_STEPS_REQUESTED = 3)
  ASSERT (NAV_STEPS_COMPLETED = 1)
  ASSERT (ENERGY = 3002)
  ASSERT (STARDATE = 1000)
  ASSERT (ENT_SX = 5)
  ASSERT (ENT_SY = 4)
END

DEF TEST_GALAXY_EDGE_COST_USES_REQUESTED_STEPS()
  INIT_GAME
  LET STARDATE = 1000
  SET_POS 8, 4, 4, 4
  RUN_NAVIGATION 1, 1.0
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_GALAXY_EDGE())
  ASSERT (NAV_STEPS_REQUESTED = 8)
  ASSERT (NAV_STEPS_COMPLETED = 4)
  ASSERT (ENERGY = 2997)
  ASSERT (STARDATE = 1001)
  ASSERT (ENT_QX = 8)
  ASSERT (ENT_SX = 8)
END

DEF TEST_QUADRANT_CROSSING_COST_USES_REQUESTED_STEPS()
  INIT_GAME
  LET STARDATE = 1000
  SET_POS 4, 4, 7, 4
  RUN_NAVIGATION 1, 0.375
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_QUADRANT_CROSSING())
  ASSERT (NAV_STEPS_REQUESTED = 3)
  ASSERT (NAV_STEPS_COMPLETED = 3)
  ASSERT (ENERGY = 3002)
  ASSERT (STARDATE = 1001)
  ASSERT (ENT_QX = 5)
  ASSERT (ENT_SX = 2)
END

DEF TEST_DECIMAL_COURSE_COST_AND_MOVE()
  INIT_GAME
  LET STARDATE = 1000
  SET_POS 4, 4, 4, 4
  RUN_NAVIGATION 1.5, 0.25
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT())
  ASSERT (NAV_STEPS_REQUESTED = 2)
  ASSERT (NAV_STEPS_COMPLETED = 2)
  ASSERT (ENERGY = 3003)
  ASSERT (STARDATE = 1000)
  ASSERT (ENT_SX = 6)
  ASSERT (ENT_SY = 3)
END

DEF TEST_DEADLINE_PATH_ENDS_GAME()
  INIT_GAME
  LET START_STARDATE = 1000
  LET MISSION_DAYS = 30
  LET STARDATE = 1031
  LET GAME_OVER = FALSE
  LET MISSION_OUTCOME = MISSION_OUTCOME_ONGOING()
  CHECK_MISSION_DEADLINE
  ASSERT GAME_OVER
  ASSERT (MISSION_OUTCOME = MISSION_OUTCOME_DEFEAT())
END

DEF TEST_NAVIGATION_WITH_NO_ENERGY_AND_SHIELDS_RETURNS_WITHOUT_MOVEMENT()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  LET ENERGY = 0
  LET SHIELDS = 100
  RUN_NAVIGATION 1, 1.0
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_NONE())
  ASSERT (NAV_STEPS_REQUESTED = 0)
  ASSERT (NAV_STEPS_COMPLETED = 0)
  ASSERT (ENT_SX = 4)
  ASSERT (ENT_SY = 4)
  ASSERT (ENERGY = 0)
  ASSERT_FALSE GAME_OVER
END

DEF TEST_NAVIGATION_WITH_NO_ENERGY_AND_NO_SHIELDS_ENDS_GAME()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  LET ENERGY = -1
  LET SHIELDS = 0
  RUN_NAVIGATION 1, 1.0
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_NONE())
  ASSERT (NAV_STEPS_REQUESTED = 0)
  ASSERT (NAV_STEPS_COMPLETED = 0)
  ASSERT (ENT_SX = 4)
  ASSERT (ENT_SY = 4)
  ASSERT (ENERGY = -1)
  ASSERT GAME_OVER
  ASSERT (MISSION_OUTCOME = MISSION_OUTCOME_DEFEAT())
END

DEF TEST_WARP_DAMAGE_GATE_REJECTS_WARP_ABOVE_POINT_TWO_WITHOUT_SIDE_EFFECTS()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  LET STARDATE = 1000
  LET ENERGY = 3000
  SET_DEVICE_DAMAGE DAMAGE_SLOT_WARP_ENGINES(), -2
  SET_DEVICE_DAMAGE DAMAGE_SLOT_PHASER_CONTROL(), -3
  CLEAR_OUTPUT_BUFFER
  RUN_NAVIGATION_WITH_ROLL 1, 0.3, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_NONE())
  ASSERT (NAV_STEPS_REQUESTED = 0)
  ASSERT (NAV_STEPS_COMPLETED = 0)
  ASSERT (ENT_QX = 4)
  ASSERT (ENT_QY = 4)
  ASSERT (ENT_SX = 4)
  ASSERT (ENT_SY = 4)
  ASSERT (STARDATE = 1000)
  ASSERT (ENERGY = 3000)
  ASSERT (@DAMAGE[DAMAGE_SLOT_WARP_ENGINES()] = -2)
  ASSERT (@DAMAGE[DAMAGE_SLOT_PHASER_CONTROL()] = -3)
  ASSERT_OUTPUT "WARP ENGINES ARE DAMAGED, MAXIMUM SPEED = WARP .2\n"
END

DEF TEST_WARP_DAMAGE_GATE_ALLOWS_WARP_POINT_TWO()
  INIT_GAME
  LET STARDATE = 1000
  SET_POS 4, 4, 4, 4
  SET_DEVICE_DAMAGE DAMAGE_SLOT_WARP_ENGINES(), -2
  RUN_NAVIGATION_WITH_ROLL 1, 0.2, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT())
  ASSERT (NAV_STEPS_REQUESTED = 1)
  ASSERT (NAV_STEPS_COMPLETED = 1)
  ASSERT (ENT_SX = 5)
  ASSERT (ENT_SY = 4)
  ASSERT (ENERGY = 3004)
  ASSERT (STARDATE = 1000)
END

DEF TEST_NAVIGATION_ENERGY_DEPLETED_AFTER_COST_DOES_NOT_END_GAME()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  LET @GALAXY[4, 4] = 0
  LET @GALAXY[5, 4] = 0
  LET KLINGONS_HERE = 0
  LET KLINGONS_LEFT = 0
  LET ENERGY = 2
  LET SHIELDS = 50
  RUN_NAVIGATION 1, 1.0
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_QUADRANT_CROSSING())
  ASSERT (NAV_STEPS_REQUESTED = 8)
  ASSERT (ENERGY = -1)
  ASSERT_FALSE GAME_OVER
END

DEF TEST_NAVIGATION_DEADLINE_REPAIRS_BEFORE_DEFEAT_AND_SKIPS_RETALIATION()
  INIT_GAME
  SET_POS 4, 4, 7, 4
  LET START_STARDATE = 2000
  LET MISSION_DAYS = 4
  LET STARDATE = 2004
  LET SHIELDS = 400
  LET DOCKED = FALSE
  LET KLINGONS_INITIAL = 3
  LET KLINGONS_LEFT = 1
  LET BASES_LEFT = 2
  LET @GALAXY[5, 4] = 100
  SET_DEVICE_DAMAGE DAMAGE_SLOT_PHASER_CONTROL(), -1
  CLEAR_OUTPUT_BUFFER
  RUN_NAVIGATION_WITH_ROLL 1, 0.375, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_QUADRANT_CROSSING())
  ASSERT (STARDATE = 2005)
  ASSERT (@DAMAGE[DAMAGE_SLOT_PHASER_CONTROL()] = 0)
  ASSERT (SHIELDS = 400)
  ASSERT GAME_OVER
  ASSERT (MISSION_OUTCOME = MISSION_OUTCOME_DEFEAT())
  ASSERT_OUTPUT "IT IS STARDATE 2005\nTHERE ARE STILL 1 KLINGON BATTLE CRUISERS\nMISSION SUMMARY\nSTARDATE 2005\nMISSION DAYS USED 5\nKLINGONS DESTROYED 2\nKLINGONS LEFT 1\nSTARBASES LEFT 2\nFINAL SCORE 400\n"
END

DEF TEST_NAVIGATION_DEADLINE_DEFEAT_SKIPS_DEAD_IN_SPACE_HANDLING()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  LET START_STARDATE = 2000
  LET MISSION_DAYS = 4
  LET STARDATE = 2004
  LET ENERGY = 2
  LET SHIELDS = 0
  LET KLINGONS_INITIAL = 3
  LET KLINGONS_LEFT = 2
  LET BASES_LEFT = 2
  LET @GALAXY[4, 4] = 0
  LET @GALAXY[5, 4] = 0
  CLEAR_OUTPUT_BUFFER
  RUN_NAVIGATION_WITH_ROLL 1, 1.0, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_QUADRANT_CROSSING())
  ASSERT (STARDATE = 2005)
  ASSERT (ENERGY = -1)
  ASSERT GAME_OVER
  ASSERT (MISSION_OUTCOME = MISSION_OUTCOME_DEFEAT())
  ASSERT_OUTPUT "IT IS STARDATE 2005\nTHERE ARE STILL 2 KLINGON BATTLE CRUISERS\nMISSION SUMMARY\nSTARDATE 2005\nMISSION DAYS USED 5\nKLINGONS DESTROYED 1\nKLINGONS LEFT 2\nSTARBASES LEFT 2\nFINAL SCORE 200\n"
END

