# trek/test_navigation_cost.tbx - navigation energy cost tests

USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "scan.tbx"
USE "nav.tbx"
USE "../../lib/tests/helper.tbx"

DEF SET_POS(QX, QY, SX, SY)
  LET ENT_QX = QX
  LET ENT_QY = QY
  CLEAR_SECTOR
  LET ENT_SX = SX
  LET ENT_SY = SY
  LET @SECTOR[ENT_SX, ENT_SY] = 1
END

DEF TEST_APPLY_NAV_ENERGY_COST_STEP_1()
  INIT_GAME
  LET ENERGY = 1000
  APPLY_NAV_ENERGY_COST 1
  ASSERT (ENERGY = 1004)
END

DEF TEST_APPLY_NAV_ENERGY_COST_STEP_8()
  INIT_GAME
  LET ENERGY = 1000
  APPLY_NAV_ENERGY_COST 8
  ASSERT (ENERGY = 997)
END

DEF TEST_FRACTIONAL_WARP_COST_AND_MOVE()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  RUN_NAVIGATION 1, 0.2
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT())
  ASSERT (NAV_STEPS_REQUESTED = 1)
  ASSERT (NAV_STEPS_COMPLETED = 1)
  ASSERT (ENERGY = 3004)
  ASSERT (ENT_SX = 5)
  ASSERT (ENT_SY = 4)
END

DEF TEST_WARP_ONE_USES_EIGHT_REQUESTED_STEPS()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  LET @SECTOR[5, 4] = 4
  RUN_NAVIGATION 1, 1.0
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_BLOCKED())
  ASSERT (NAV_STEPS_REQUESTED = 8)
  ASSERT (NAV_STEPS_COMPLETED = 0)
  ASSERT (ENERGY = 2997)
END

DEF TEST_BLOCKED_COST_USES_REQUESTED_STEPS()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  LET @SECTOR[6, 4] = 4
  RUN_NAVIGATION 1, 0.375
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_BLOCKED())
  ASSERT (NAV_STEPS_REQUESTED = 3)
  ASSERT (NAV_STEPS_COMPLETED = 1)
  ASSERT (ENERGY = 3002)
  ASSERT (ENT_SX = 5)
  ASSERT (ENT_SY = 4)
END

DEF TEST_GALAXY_EDGE_COST_USES_REQUESTED_STEPS()
  INIT_GAME
  SET_POS 8, 4, 4, 4
  RUN_NAVIGATION 1, 1.0
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_GALAXY_EDGE())
  ASSERT (NAV_STEPS_REQUESTED = 8)
  ASSERT (NAV_STEPS_COMPLETED = 4)
  ASSERT (ENERGY = 2997)
  ASSERT (ENT_QX = 8)
  ASSERT (ENT_SX = 8)
END

DEF TEST_QUADRANT_CROSSING_COST_USES_REQUESTED_STEPS()
  INIT_GAME
  SET_POS 4, 4, 7, 4
  RUN_NAVIGATION 1, 0.375
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_QUADRANT_CROSSING())
  ASSERT (NAV_STEPS_REQUESTED = 3)
  ASSERT (NAV_STEPS_COMPLETED = 2)
  ASSERT (ENERGY = 3002)
  ASSERT (ENT_QX = 5)
  ASSERT (ENT_SX = 1)
END

TEST_APPLY_NAV_ENERGY_COST_STEP_1
TEST_APPLY_NAV_ENERGY_COST_STEP_8
TEST_FRACTIONAL_WARP_COST_AND_MOVE
TEST_WARP_ONE_USES_EIGHT_REQUESTED_STEPS
TEST_BLOCKED_COST_USES_REQUESTED_STEPS
TEST_GALAXY_EDGE_COST_USES_REQUESTED_STEPS
TEST_QUADRANT_CROSSING_COST_USES_REQUESTED_STEPS
