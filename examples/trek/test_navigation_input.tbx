# trek/test_navigation_input.tbx — IS_VALID_COURSE / IS_VALID_WARP smoke tests

USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "scan.tbx"
USE "combat.tbx"
USE "nav.tbx"
USE "../../lib/tests/helper.tbx"

# IS_VALID_COURSE: 1 <= COURSE < 9 は有効 (truthy) — 小数可
# IS_VALID_COURSE は Bool を返すため ASSERT に直接渡す
DEF TEST_VALID_COURSES()
  ASSERT IS_VALID_COURSE(1)
  ASSERT IS_VALID_COURSE(1.5)
  ASSERT IS_VALID_COURSE(8)
  ASSERT IS_VALID_COURSE(8.999)
END

# IS_VALID_COURSE: COURSE < 1 または COURSE >= 9 は無効 (falsy) — 小数可
# 9 はコーステーブルの sentinel だが入力としては拒否する
DEF TEST_INVALID_COURSES()
  ASSERT_FALSE IS_VALID_COURSE(0)
  ASSERT_FALSE IS_VALID_COURSE(0.999)
  ASSERT_FALSE IS_VALID_COURSE(9)
  ASSERT_FALSE IS_VALID_COURSE(9.0)
  ASSERT_FALSE IS_VALID_COURSE(-1)
  ASSERT_FALSE IS_VALID_COURSE(10)
END

# IS_VALID_WARP: 0 <= WARP <= 8 は有効 (truthy) — 小数可 (Mayfield 原典どおり)
DEF TEST_VALID_WARPS()
  ASSERT IS_VALID_WARP(0)
  ASSERT IS_VALID_WARP(0.2)
  ASSERT IS_VALID_WARP(1)
  ASSERT IS_VALID_WARP(8)
  ASSERT IS_VALID_WARP(8.0)
END

# IS_VALID_WARP: WARP < 0 または WARP > 8 は無効 (falsy) — 小数可
DEF TEST_INVALID_WARPS()
  ASSERT_FALSE IS_VALID_WARP(-1)
  ASSERT_FALSE IS_VALID_WARP(-0.1)
  ASSERT_FALSE IS_VALID_WARP(8.1)
  ASSERT_FALSE IS_VALID_WARP(9)
END

TEST_VALID_COURSES
TEST_INVALID_COURSES
TEST_VALID_WARPS
TEST_INVALID_WARPS
