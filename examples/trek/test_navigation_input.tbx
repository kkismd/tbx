# trek/test_navigation_input.tbx — IS_VALID_COURSE / IS_VALID_WARP smoke tests

USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "scan.tbx"
USE "nav.tbx"
USE "../../lib/tests/helper.tbx"

# IS_VALID_COURSE: 1..8 は有効 (true)
DEF TEST_VALID_COURSES()
  ASSERT (IS_VALID_COURSE(1) = 1)
  ASSERT (IS_VALID_COURSE(2) = 1)
  ASSERT (IS_VALID_COURSE(3) = 1)
  ASSERT (IS_VALID_COURSE(4) = 1)
  ASSERT (IS_VALID_COURSE(5) = 1)
  ASSERT (IS_VALID_COURSE(6) = 1)
  ASSERT (IS_VALID_COURSE(7) = 1)
  ASSERT (IS_VALID_COURSE(8) = 1)
END

# IS_VALID_COURSE: 0, 9 以上は無効 (false)
# 9 はコーステーブルの sentinel だが入力としては拒否する
DEF TEST_INVALID_COURSES()
  ASSERT (IS_VALID_COURSE(0) = 0)
  ASSERT (IS_VALID_COURSE(9) = 0)
  ASSERT (IS_VALID_COURSE(-1) = 0)
  ASSERT (IS_VALID_COURSE(10) = 0)
END

# IS_VALID_WARP: 1..8 は有効 (true)
DEF TEST_VALID_WARPS()
  ASSERT (IS_VALID_WARP(1) = 1)
  ASSERT (IS_VALID_WARP(2) = 1)
  ASSERT (IS_VALID_WARP(3) = 1)
  ASSERT (IS_VALID_WARP(4) = 1)
  ASSERT (IS_VALID_WARP(5) = 1)
  ASSERT (IS_VALID_WARP(6) = 1)
  ASSERT (IS_VALID_WARP(7) = 1)
  ASSERT (IS_VALID_WARP(8) = 1)
END

# IS_VALID_WARP: 0, 9 以上は無効 (false)
DEF TEST_INVALID_WARPS()
  ASSERT (IS_VALID_WARP(0) = 0)
  ASSERT (IS_VALID_WARP(9) = 0)
  ASSERT (IS_VALID_WARP(-1) = 0)
END

TEST_VALID_COURSES
TEST_INVALID_COURSES
TEST_VALID_WARPS
TEST_INVALID_WARPS
