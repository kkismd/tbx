# trek/test_navigation_input.tbx — IS_VALID_COURSE / IS_VALID_WARP smoke tests

USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "scan.tbx"
USE "nav.tbx"
USE "../../lib/tests/helper.tbx"

# IS_VALID_COURSE: 1 <= COURSE < 9 は有効 (true) — 小数可
DEF TEST_VALID_COURSES()
  ASSERT (IS_VALID_COURSE(1) = 1)
  ASSERT (IS_VALID_COURSE(1.5) = 1)
  ASSERT (IS_VALID_COURSE(8) = 1)
  ASSERT (IS_VALID_COURSE(8.999) = 1)
END

# IS_VALID_COURSE: COURSE < 1 または COURSE >= 9 は無効 (false) — 小数可
# 9 はコーステーブルの sentinel だが入力としては拒否する
DEF TEST_INVALID_COURSES()
  ASSERT (IS_VALID_COURSE(0) = 0)
  ASSERT (IS_VALID_COURSE(0.999) = 0)
  ASSERT (IS_VALID_COURSE(9) = 0)
  ASSERT (IS_VALID_COURSE(9.0) = 0)
  ASSERT (IS_VALID_COURSE(-1) = 0)
  ASSERT (IS_VALID_COURSE(10) = 0)
END

# IS_VALID_WARP: 0 <= WARP <= 8 は有効 (true) — 小数可 (Mayfield 原典どおり)
DEF TEST_VALID_WARPS()
  ASSERT (IS_VALID_WARP(0) = 1)
  ASSERT (IS_VALID_WARP(0.2) = 1)
  ASSERT (IS_VALID_WARP(1) = 1)
  ASSERT (IS_VALID_WARP(8) = 1)
  ASSERT (IS_VALID_WARP(8.0) = 1)
END

# IS_VALID_WARP: WARP < 0 または WARP > 8 は無効 (false) — 小数可
DEF TEST_INVALID_WARPS()
  ASSERT (IS_VALID_WARP(-1) = 0)
  ASSERT (IS_VALID_WARP(-0.1) = 0)
  ASSERT (IS_VALID_WARP(8.1) = 0)
  ASSERT (IS_VALID_WARP(9) = 0)
END

TEST_VALID_COURSES
TEST_INVALID_COURSES
TEST_VALID_WARPS
TEST_INVALID_WARPS
