# trek/test_navigation_repair.tbx - navigation-triggered device repair tests

USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "scan.tbx"
USE "combat.tbx"
USE "nav.tbx"
USE "../../lib/tests/helper.tbx"

DEF SET_POS(QX, QY, SX, SY)
  LET ENT_QX = QX
  LET ENT_QY = QY
  CLEAR_SECTOR
  LET ENT_SX = SX
  LET ENT_SY = SY
  LET @SECTOR[ENT_SX, ENT_SY] = 1
END

DEF TEST_SAME_QUADRANT_MOVE_REPAIRS_DAMAGE()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  SET_DEVICE_DAMAGE DAMAGE_SLOT_PHASER_CONTROL(), -3
  LET DOCKED = FALSE
  RUN_NAVIGATION_WITH_ROLL 1, 0.2, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT())
  ASSERT (@DAMAGE[DAMAGE_SLOT_PHASER_CONTROL()] = -2)
END

DEF TEST_BLOCKED_MOVE_STILL_REPAIRS_DAMAGE()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  SET_DEVICE_DAMAGE DAMAGE_SLOT_PHASER_CONTROL(), -3
  LET @SECTOR[6, 4] = 4
  LET DOCKED = FALSE
  RUN_NAVIGATION_WITH_ROLL 1, 0.375, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_BLOCKED())
  ASSERT (@DAMAGE[DAMAGE_SLOT_PHASER_CONTROL()] = -2)
END

DEF TEST_GALAXY_EDGE_MOVE_STILL_REPAIRS_DAMAGE()
  INIT_GAME
  SET_POS 8, 4, 4, 4
  SET_DEVICE_DAMAGE DAMAGE_SLOT_PHASER_CONTROL(), -3
  LET DOCKED = FALSE
  RUN_NAVIGATION_WITH_ROLL 1, 1.0, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_GALAXY_EDGE())
  ASSERT (@DAMAGE[DAMAGE_SLOT_PHASER_CONTROL()] = -2)
END

DEF TEST_QUADRANT_CROSSING_MOVE_STILL_REPAIRS_DAMAGE()
  INIT_GAME
  SET_POS 4, 4, 7, 4
  SET_DEVICE_DAMAGE DAMAGE_SLOT_PHASER_CONTROL(), -3
  LET DOCKED = FALSE
  RUN_NAVIGATION_WITH_ROLL 1, 0.375, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_QUADRANT_CROSSING())
  ASSERT (@DAMAGE[DAMAGE_SLOT_PHASER_CONTROL()] = -2)
END

DEF TEST_DOCKED_MOVE_KEEPS_EXISTING_REPAIR_RATE()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  SET_DEVICE_DAMAGE DAMAGE_SLOT_PHASER_CONTROL(), -3
  LET DOCKED = TRUE
  RUN_NAVIGATION_WITH_ROLL 1, 0.2, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT())
  ASSERT (@DAMAGE[DAMAGE_SLOT_PHASER_CONTROL()] = -1)
END

DEF TEST_WARP_TOO_LOW_DOES_NOT_REPAIR_DAMAGE()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  SET_DEVICE_DAMAGE DAMAGE_SLOT_PHASER_CONTROL(), -3
  LET DOCKED = FALSE
  RUN_NAVIGATION_WITH_ROLL 1, 0.1, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_NONE())
  ASSERT (@DAMAGE[DAMAGE_SLOT_PHASER_CONTROL()] = -3)
END

DEF TEST_ENERGY_PRECHECK_DOES_NOT_REPAIR_DAMAGE()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  SET_DEVICE_DAMAGE DAMAGE_SLOT_PHASER_CONTROL(), -3
  LET ENERGY = 0
  LET SHIELDS = 100
  LET DOCKED = FALSE
  RUN_NAVIGATION_WITH_ROLL 1, 1.0, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_NONE())
  ASSERT (@DAMAGE[DAMAGE_SLOT_PHASER_CONTROL()] = -3)
END

TEST_SAME_QUADRANT_MOVE_REPAIRS_DAMAGE
TEST_BLOCKED_MOVE_STILL_REPAIRS_DAMAGE
TEST_GALAXY_EDGE_MOVE_STILL_REPAIRS_DAMAGE
TEST_QUADRANT_CROSSING_MOVE_STILL_REPAIRS_DAMAGE
TEST_DOCKED_MOVE_KEEPS_EXISTING_REPAIR_RATE
TEST_WARP_TOO_LOW_DOES_NOT_REPAIR_DAMAGE
TEST_ENERGY_PRECHECK_DOES_NOT_REPAIR_DAMAGE
