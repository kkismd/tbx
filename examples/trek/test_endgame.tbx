USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "scan.tbx"
USE "combat.tbx"
USE "nav.tbx"
USE "command.tbx"
USE "../../lib/tests/helper.tbx"

DEF CLEAR_OUTPUT_BUFFER()
  VAR DISCARDED = GET_OUTPUT()
END

DEF SET_KLINGON(I, SX, SY, E)
  LET @K_X[I] = SX
  LET @K_Y[I] = SY
  LET @K_E[I] = E
END

DEF SET_CURRENT_QUADRANT_SUMMARY(KLINGON_COUNT, BASE_COUNT, STAR_COUNT)
  LET @GALAXY[ENT_QX, ENT_QY] = ENCODE_QUADRANT_SUMMARY(KLINGON_COUNT, BASE_COUNT, STAR_COUNT)
  LET @CHART[ENT_QX, ENT_QY] = ENCODE_QUADRANT_SUMMARY(KLINGON_COUNT, BASE_COUNT, STAR_COUNT)
  LET KLINGONS_HERE = KLINGON_COUNT
  LET BASES_HERE = BASE_COUNT
  LET STARS_HERE = STAR_COUNT
END

DEF SETUP_ENDGAME_STATE()
  INIT_GAME
  LET START_STARDATE = 2000
  LET STARDATE = 2005
  LET KLINGONS_INITIAL = 7
  LET KLINGONS_LEFT = 2
  LET BASES_LEFT = 1
  LET ENT_QX = 4
  LET ENT_QY = 5
  LET ENT_SX = 4
  LET ENT_SY = 4
  CLEAR_SECTOR
  LET @SECTOR[ENT_SX, ENT_SY] = 1
END

DEF TEST_VICTORY_PRINTS_SUMMARY_AND_SCORE()
  SETUP_ENDGAME_STATE
  LET KLINGONS_HERE = 1
  LET KLINGONS_LEFT = 1
  SET_CURRENT_QUADRANT_SUMMARY 1, 0, 0
  SET_KLINGON 1, 6, 4, 200
  LET @SECTOR[6, 4] = 2
  CLEAR_OUTPUT_BUFFER
  DESTROY_KLINGON 1
  ASSERT GAME_OVER
  ASSERT (MISSION_OUTCOME = MISSION_OUTCOME_VICTORY())
  ASSERT_OUTPUT "THE LAST KLINGON BATTLE CRUISER IN THE GALAXY HAS BEEN DESTROYED\nTHE FEDERATION HAS BEEN SAVED !!!\nMISSION SUMMARY\nSTARDATE 2005\nMISSION DAYS USED 5\nKLINGONS DESTROYED 7\nKLINGONS LEFT 0\nSTARBASES LEFT 1\nFINAL SCORE 1400\n"
END

DEF TEST_DEFEAT_AFTER_SHIELD_UNDERFLOW_PRINTS_SUMMARY_AND_SCORE()
  SETUP_ENDGAME_STATE
  LET SHIELDS = -1
  CLEAR_OUTPUT_BUFFER
  MAYBE_DEFEAT_AFTER_KLINGON_ATTACK
  ASSERT GAME_OVER
  ASSERT (MISSION_OUTCOME = MISSION_OUTCOME_DEFEAT())
  ASSERT_OUTPUT "THE ENTERPRISE HAS BEEN DESTROYED. THE FEDERATION WILL BE CONQUERED\nTHERE ARE STILL 2 KLINGON BATTLE CRUISERS\nMISSION SUMMARY\nSTARDATE 2005\nMISSION DAYS USED 5\nKLINGONS DESTROYED 5\nKLINGONS LEFT 2\nSTARBASES LEFT 1\nFINAL SCORE 1000\n"
END

DEF TEST_MISSION_DEADLINE_ENDS_GAME()
  SETUP_ENDGAME_STATE
  LET MISSION_DAYS = 4
  CLEAR_OUTPUT_BUFFER
  CHECK_MISSION_DEADLINE
  ASSERT GAME_OVER
  ASSERT (MISSION_OUTCOME = MISSION_OUTCOME_DEFEAT())
  ASSERT_OUTPUT "IT IS STARDATE 2005\nTHERE ARE STILL 2 KLINGON BATTLE CRUISERS\nMISSION SUMMARY\nSTARDATE 2005\nMISSION DAYS USED 5\nKLINGONS DESTROYED 5\nKLINGONS LEFT 2\nSTARBASES LEFT 1\nFINAL SCORE 1000\n"
END

DEF TEST_RUN_COMMAND_LOOP_RETURNS_IMMEDIATELY_AFTER_GAME_OVER()
  INIT_GAME
  LET GAME_OVER = TRUE
  LET MISSION_OUTCOME = MISSION_OUTCOME_DEFEAT()
  CLEAR_OUTPUT_BUFFER
  RUN_COMMAND_LOOP
  ASSERT_OUTPUT ""
END

TEST_VICTORY_PRINTS_SUMMARY_AND_SCORE
TEST_DEFEAT_AFTER_SHIELD_UNDERFLOW_PRINTS_SUMMARY_AND_SCORE
TEST_MISSION_DEADLINE_ENDS_GAME
TEST_RUN_COMMAND_LOOP_RETURNS_IMMEDIATELY_AFTER_GAME_OVER
