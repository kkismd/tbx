USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "scan.tbx"
USE "combat.tbx"
USE "nav.tbx"
USE "../../lib/tests/helper.tbx"

DEF SET_POS(QX, QY, SX, SY)
  LET ENT_QX = QX
  LET ENT_QY = QY
  CLEAR_SECTOR
  LET ENT_SX = SX
  LET ENT_SY = SY
  LET @SECTOR[ENT_SX, ENT_SY] = 1
END

DEF CLEAR_OUTPUT_BUFFER()
  VAR DISCARDED = GET_OUTPUT()
END

DEF SET_SAFE_QUADRANT()
  LET @GALAXY[ENT_QX, ENT_QY] = 0
  LET KLINGONS_HERE = 0
  LET KLINGONS_LEFT = 0
  LET BASES_HERE = 0
  LET STARS_HERE = 0
END

DEF TEST_NAV_RANDOM_DAMAGE_EVENT_APPLIES_DAMAGE_AND_PRINTS_REPORT()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  SET_SAFE_QUADRANT
  LET DOCKED = FALSE
  CLEAR_OUTPUT_BUFFER
  RUN_NAVIGATION_WITH_EVENT 1, 0.2, 20, DAMAGE_SLOT_PHASER_CONTROL(), FALSE, 3, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT())
  ASSERT (@DAMAGE[DAMAGE_SLOT_PHASER_CONTROL()] = -3)
  ASSERT_OUTPUT "DAMAGE CONTROL REPORT: PHASER CONTROL DAMAGED\n"
END

DEF TEST_NAV_RANDOM_REPAIR_EVENT_CAN_CREATE_REPAIRING_STATE()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  SET_SAFE_QUADRANT
  LET DOCKED = FALSE
  CLEAR_OUTPUT_BUFFER
  RUN_NAVIGATION_WITH_EVENT 1, 0.2, 20, DAMAGE_SLOT_SHIELD_CONTROL(), TRUE, 4, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT())
  ASSERT (@DAMAGE[DAMAGE_SLOT_SHIELD_CONTROL()] = 4)
  ASSERT_OUTPUT "DAMAGE CONTROL REPORT: SHIELD CONTROL STATE OF REPAIR IMPROVED\n"
END

DEF TEST_NAV_RANDOM_EVENT_SKIP_LEAVES_ONLY_REPAIR_TICK_EFFECT()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  SET_SAFE_QUADRANT
  SET_DEVICE_DAMAGE DAMAGE_SLOT_PHASER_CONTROL(), -3
  LET DOCKED = FALSE
  CLEAR_OUTPUT_BUFFER
  RUN_NAVIGATION_WITH_EVENT 1, 0.2, 21, DAMAGE_SLOT_PHASER_CONTROL(), FALSE, 5, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT())
  ASSERT (@DAMAGE[DAMAGE_SLOT_PHASER_CONTROL()] = -2)
  ASSERT_OUTPUT ""
END

DEF TEST_NAV_RANDOM_EVENT_RUNS_BEFORE_BLOCKED_MOVEMENT()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  SET_SAFE_QUADRANT
  LET @SECTOR[6, 4] = 4
  LET DOCKED = FALSE
  CLEAR_OUTPUT_BUFFER
  RUN_NAVIGATION_WITH_EVENT 1, 0.375, 20, DAMAGE_SLOT_WARP_ENGINES(), FALSE, 2, 100
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_BLOCKED())
  ASSERT (@DAMAGE[DAMAGE_SLOT_WARP_ENGINES()] = -2)
  ASSERT_OUTPUT "DAMAGE CONTROL REPORT: WARP ENGINES DAMAGED\nCOURSE BLOCKED BY STAR -- MOVEMENT ABORTED\n"
END

TEST_NAV_RANDOM_DAMAGE_EVENT_APPLIES_DAMAGE_AND_PRINTS_REPORT
TEST_NAV_RANDOM_REPAIR_EVENT_CAN_CREATE_REPAIRING_STATE
TEST_NAV_RANDOM_EVENT_SKIP_LEAVES_ONLY_REPAIR_TICK_EFFECT
TEST_NAV_RANDOM_EVENT_RUNS_BEFORE_BLOCKED_MOVEMENT
