# trek/test_scan.tbx — SHORT_RANGE_SCAN() smoke test
# SECTOR_SYMBOL の変換と INIT_GAME 後の初期状態を検証する
# empty sector は原典の空白ではなく readability 改善のため " . " を使う

USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "scan.tbx"
USE "../../lib/tests/helper.tbx"

DEF CLEAR_OUTPUT_BUFFER()
  VAR DISCARDED = GET_OUTPUT()
END

DEF RUN_SMOKE_TEST()
  INIT_GAME

  # Intentional deviation from Mayfield STTR1: empty sector uses " . ".
  ASSERT (SECTOR_SYMBOL(0) = " . ")
  ASSERT (SECTOR_SYMBOL(1) = "<*>")
  ASSERT (SECTOR_SYMBOL(2) = "+++")
  ASSERT (SECTOR_SYMBOL(3) = ">!<")
  ASSERT (SECTOR_SYMBOL(4) = " * ")

  # INIT_GAME 後にエネルギー・武装・スターデート・フラグが初期化されているか検証する
  ASSERT (ENERGY = 3000)
  ASSERT (MAX_ENERGY = 3000)
  ASSERT (TORPEDOES = 10)
  ASSERT (MAX_TORPEDOES = 10)
  ASSERT (SHIELDS = 0)
  ASSERT (STARDATE > 0)
  ASSERT (STARDATE = START_STARDATE)
  ASSERT_FALSE DOCKED
  ASSERT_FALSE GAME_OVER

  # Enterprise セルが @SECTOR[ENT_SX, ENT_SY] に配置されている
  ASSERT (@SECTOR[ENT_SX, ENT_SY] = 1)

  # SHORT_RANGE_SCAN を呼び出してもクラッシュしないこと
  SHORT_RANGE_SCAN
END

# docking 判定のテスト: Enterprise 隣接セルに Starbase を置いて DOCKED になるか確認する
DEF TEST_DOCKING()
  INIT_GAME
  # Enterprise 周辺のセルに Starbase (3) を配置する
  # ENT_SX + 1 が境界内なら使う、そうでなければ ENT_SX - 1 を使う
  VAR SB_SX = ENT_SX + 1
  VAR SB_SY = ENT_SY
  IF SB_SX > 8
    LET SB_SX = ENT_SX - 1
  ENDIF
  LET @SECTOR[SB_SX, SB_SY] = 3
  # ENERGY を少し減らして補給を確認する
  LET ENERGY = ENERGY - 100
  CHECK_DOCKING
  ASSERT (CONDITION = "DOCKED")
  ASSERT DOCKED
  ASSERT (ENERGY = MAX_ENERGY)
  ASSERT (TORPEDOES = MAX_TORPEDOES)
  ASSERT (SHIELDS = 0)
END

DEF TEST_STATUS_LINE_SHIELDS_PRINTS_INTEGER_WITHOUT_CHANGING_INTERNAL_VALUE()
  INIT_GAME
  LET SHIELDS = 828.7178040480228
  CLEAR_OUTPUT_BUFFER
  PRINT_STATUS_LINE 7
  ASSERT_OUTPUT "   SHIELDS         828\n"
  ASSERT (SHIELDS = 828.7178040480228)
END

RUN_SMOKE_TEST
TEST_DOCKING
TEST_STATUS_LINE_SHIELDS_PRINTS_INTEGER_WITHOUT_CHANGING_INTERNAL_VALUE
