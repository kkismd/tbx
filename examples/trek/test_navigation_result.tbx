# trek/test_navigation_result.tbx - MOVE_WITHIN_QUADRANT() movement result state tests

USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "scan.tbx"
USE "nav.tbx"
USE "../../lib/tests/helper.tbx"

DEF SET_POS(QX, QY, SX, SY)
  LET ENT_QX = QX
  LET ENT_QY = QY
  CLEAR_SECTOR
  LET ENT_SX = SX
  LET ENT_SY = SY
  LET @SECTOR[ENT_SX, ENT_SY] = 1
END

DEF TEST_SAME_QUADRANT_RESULT()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  MOVE_WITHIN_QUADRANT 1, 2
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_SAME_QUADRANT())
  ASSERT (NAV_STEPS_REQUESTED = 2)
  ASSERT (NAV_STEPS_COMPLETED = 2)
  ASSERT (ENT_SX = 6)
  ASSERT (ENT_SY = 4)
END

DEF TEST_BLOCKED_RESULT()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  LET @SECTOR[6, 4] = 4
  MOVE_WITHIN_QUADRANT 1, 3
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_BLOCKED())
  ASSERT (NAV_STEPS_REQUESTED = 3)
  ASSERT (NAV_STEPS_COMPLETED = 1)
  ASSERT (ENT_SX = 5)
  ASSERT (ENT_SY = 4)
END

DEF TEST_IMMEDIATE_BLOCKED_RESULT()
  INIT_GAME
  SET_POS 4, 4, 4, 4
  LET @SECTOR[5, 4] = 3
  MOVE_WITHIN_QUADRANT 1, 1
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_BLOCKED())
  ASSERT (NAV_STEPS_REQUESTED = 1)
  ASSERT (NAV_STEPS_COMPLETED = 0)
  ASSERT (ENT_SX = 4)
  ASSERT (ENT_SY = 4)
END

DEF TEST_QUADRANT_CROSSING_RESULT()
  INIT_GAME
  SET_POS 4, 4, 8, 4
  MOVE_WITHIN_QUADRANT 1, 1
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_QUADRANT_CROSSING())
  ASSERT (NAV_STEPS_REQUESTED = 1)
  ASSERT (NAV_STEPS_COMPLETED = 1)
  ASSERT (ENT_QX = 5)
  ASSERT (ENT_SX = 1)
END

DEF TEST_CROSSING_AFTER_CLEAR_STEPS_RESULT()
  INIT_GAME
  SET_POS 4, 4, 7, 4
  MOVE_WITHIN_QUADRANT 1, 3
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_QUADRANT_CROSSING())
  ASSERT (NAV_STEPS_REQUESTED = 3)
  ASSERT (NAV_STEPS_COMPLETED = 2)
  ASSERT (ENT_QX = 5)
  ASSERT (ENT_SX = 1)
END

DEF TEST_GALAXY_EDGE_RESULT()
  INIT_GAME
  SET_POS 8, 4, 4, 4
  MOVE_WITHIN_QUADRANT 1, 10
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_GALAXY_EDGE())
  ASSERT (NAV_STEPS_REQUESTED = 10)
  ASSERT (NAV_STEPS_COMPLETED = 4)
  ASSERT (ENT_QX = 8)
  ASSERT (ENT_SX = 8)
END

DEF TEST_IMMEDIATE_GALAXY_EDGE_RESULT()
  INIT_GAME
  SET_POS 8, 4, 8, 4
  MOVE_WITHIN_QUADRANT 1, 1
  ASSERT (NAV_MOVE_RESULT = NAV_RESULT_GALAXY_EDGE())
  ASSERT (NAV_STEPS_REQUESTED = 1)
  ASSERT (NAV_STEPS_COMPLETED = 0)
  ASSERT (ENT_QX = 8)
  ASSERT (ENT_SX = 8)
END

TEST_SAME_QUADRANT_RESULT
TEST_BLOCKED_RESULT
TEST_IMMEDIATE_BLOCKED_RESULT
TEST_QUADRANT_CROSSING_RESULT
TEST_CROSSING_AFTER_CLEAR_STEPS_RESULT
TEST_GALAXY_EDGE_RESULT
TEST_IMMEDIATE_GALAXY_EDGE_RESULT
