# trek/test_navigation_quadrant.tbx — NORMALIZE_SECTOR_CROSSING() direct tests
#
# 検証観点:
#   - X+ 越境: SX=9 -> QX+1, SX=1
#   - X- 越境: SX=0 -> QX-1, SX=8
#   - Y+ 越境: SY=9 -> QY+1, SY=1
#   - Y- 越境: SY=0 -> QY-1, SY=8
#   - X/Y 同時越境 (両方 +)
#   - X/Y 同時越境 (両方 -)
#   - galaxy 内なら NORM_IN_GALAXY は truthy
#   - galaxy 外なら NORM_IN_GALAXY は falsy (QX=8, SX=9 -> QX=9)
#   - 越境なしなら NORM_CROSSED = 0

USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "scan.tbx"
USE "nav.tbx"
USE "../../lib/tests/helper.tbx"

# Helper: quadrant と sector を指定して Enterprise を配置する
DEF SET_POS(QX, QY, SX, SY)
  LET ENT_QX = QX
  LET ENT_QY = QY
  CLEAR_SECTOR
  LET ENT_SX = SX
  LET ENT_SY = SY
  LET @SECTOR[ENT_SX, ENT_SY] = 1
END

# X+ 越境: QX=4, SX=9 -> QX=5, SX=1
DEF TEST_WRAP_X_PLUS()
  NORMALIZE_SECTOR_CROSSING 4, 4, 9, 4
  ASSERT (NORM_QX = 5)
  ASSERT (NORM_SX = 1)
  ASSERT (NORM_QY = 4)
  ASSERT (NORM_SY = 4)
  ASSERT (NORM_CROSSED = 1)
  ASSERT NORM_IN_GALAXY
END

# X- 越境: QX=4, SX=0 -> QX=3, SX=8
DEF TEST_WRAP_X_MINUS()
  NORMALIZE_SECTOR_CROSSING 4, 4, 0, 4
  ASSERT (NORM_QX = 3)
  ASSERT (NORM_SX = 8)
  ASSERT (NORM_QY = 4)
  ASSERT (NORM_SY = 4)
  ASSERT (NORM_CROSSED = 1)
  ASSERT NORM_IN_GALAXY
END

# Y+ 越境: QY=4, SY=9 -> QY=5, SY=1
DEF TEST_WRAP_Y_PLUS()
  NORMALIZE_SECTOR_CROSSING 4, 4, 4, 9
  ASSERT (NORM_QX = 4)
  ASSERT (NORM_SX = 4)
  ASSERT (NORM_QY = 5)
  ASSERT (NORM_SY = 1)
  ASSERT (NORM_CROSSED = 1)
  ASSERT NORM_IN_GALAXY
END

# Y- 越境: QY=4, SY=0 -> QY=3, SY=8
DEF TEST_WRAP_Y_MINUS()
  NORMALIZE_SECTOR_CROSSING 4, 4, 4, 0
  ASSERT (NORM_QX = 4)
  ASSERT (NORM_SX = 4)
  ASSERT (NORM_QY = 3)
  ASSERT (NORM_SY = 8)
  ASSERT (NORM_CROSSED = 1)
  ASSERT NORM_IN_GALAXY
END

# X/Y 同時越境 (+): SX=9, SY=9 -> QX+1, SX=1 / QY+1, SY=1
DEF TEST_WRAP_XY_PLUS()
  NORMALIZE_SECTOR_CROSSING 4, 4, 9, 9
  ASSERT (NORM_QX = 5)
  ASSERT (NORM_SX = 1)
  ASSERT (NORM_QY = 5)
  ASSERT (NORM_SY = 1)
  ASSERT (NORM_CROSSED = 1)
  ASSERT NORM_IN_GALAXY
END

# X/Y 同時越境 (-): SX=0, SY=0 -> QX-1, SX=8 / QY-1, SY=8
DEF TEST_WRAP_XY_MINUS()
  NORMALIZE_SECTOR_CROSSING 4, 4, 0, 0
  ASSERT (NORM_QX = 3)
  ASSERT (NORM_SX = 8)
  ASSERT (NORM_QY = 3)
  ASSERT (NORM_SY = 8)
  ASSERT (NORM_CROSSED = 1)
  ASSERT NORM_IN_GALAXY
END

# galaxy 外: QX=8, SX=9 -> QX=9 (1..8 外) -> NORM_IN_GALAXY = 0
DEF TEST_OUT_OF_GALAXY()
  NORMALIZE_SECTOR_CROSSING 8, 4, 9, 4
  ASSERT (NORM_QX = 9)
  ASSERT (NORM_SX = 1)
  ASSERT_FALSE NORM_IN_GALAXY
END

# galaxy 外 (Y): QY=8, SY=9 -> QY=9 -> NORM_IN_GALAXY は falsy
DEF TEST_OUT_OF_GALAXY_Y()
  NORMALIZE_SECTOR_CROSSING 4, 8, 4, 9
  ASSERT (NORM_QY = 9)
  ASSERT (NORM_SY = 1)
  ASSERT_FALSE NORM_IN_GALAXY
END

# 越境なし: SX=4, SY=4 は bounds 内 -> NORM_CROSSED = 0, NORM_IN_GALAXY は truthy
DEF TEST_NO_CROSSING()
  NORMALIZE_SECTOR_CROSSING 4, 4, 4, 4
  ASSERT (NORM_QX = 4)
  ASSERT (NORM_QY = 4)
  ASSERT (NORM_SX = 4)
  ASSERT (NORM_SY = 4)
  ASSERT (NORM_CROSSED = 0)
  ASSERT NORM_IN_GALAXY
END

TEST_WRAP_X_PLUS
TEST_WRAP_X_MINUS
TEST_WRAP_Y_PLUS
TEST_WRAP_Y_MINUS
TEST_WRAP_XY_PLUS
TEST_WRAP_XY_MINUS
TEST_OUT_OF_GALAXY
TEST_OUT_OF_GALAXY_Y
TEST_NO_CROSSING

# ---- MOVE_WITHIN_QUADRANT quadrant crossing 接続テスト ----

# East crossing: QX=4, SX=8 から east 1 step -> QX=5, SX=1
DEF TEST_CROSS_EAST()
  INIT_GAME
  SET_POS 4, 4, 8, 4
  MOVE_WITHIN_QUADRANT 1, 1
  ASSERT (ENT_QX = 5)
  ASSERT (ENT_SX = 1)
  ASSERT (ENT_QY = 4)
  ASSERT (ENT_SY = 4)
  ASSERT (@SECTOR[ENT_SX, ENT_SY] = 1)
END

# West crossing: QX=4, SX=1 から west 1 step -> QX=3, SX=8
DEF TEST_CROSS_WEST()
  INIT_GAME
  SET_POS 4, 4, 1, 4
  MOVE_WITHIN_QUADRANT 5, 1
  ASSERT (ENT_QX = 3)
  ASSERT (ENT_SX = 8)
  ASSERT (ENT_QY = 4)
  ASSERT (ENT_SY = 4)
  ASSERT (@SECTOR[ENT_SX, ENT_SY] = 1)
END

# South crossing: QY=4, SY=8 から south 1 step -> QY=5, SY=1
DEF TEST_CROSS_SOUTH()
  INIT_GAME
  SET_POS 4, 4, 4, 8
  MOVE_WITHIN_QUADRANT 7, 1
  ASSERT (ENT_QX = 4)
  ASSERT (ENT_SX = 4)
  ASSERT (ENT_QY = 5)
  ASSERT (ENT_SY = 1)
  ASSERT (@SECTOR[ENT_SX, ENT_SY] = 1)
END

# North crossing: QY=4, SY=1 から north 1 step -> QY=3, SY=8
DEF TEST_CROSS_NORTH()
  INIT_GAME
  SET_POS 4, 4, 4, 1
  MOVE_WITHIN_QUADRANT 3, 1
  ASSERT (ENT_QX = 4)
  ASSERT (ENT_SX = 4)
  ASSERT (ENT_QY = 3)
  ASSERT (ENT_SY = 8)
  ASSERT (@SECTOR[ENT_SX, ENT_SY] = 1)
END

# crossing 後 INIT_QUADRANT が呼ばれて @SECTOR が再構築される (scan が crash しない)
DEF TEST_CROSS_SCAN_NO_CRASH()
  INIT_GAME
  SET_POS 4, 4, 8, 4
  MOVE_WITHIN_QUADRANT 1, 1
  # crossing 後に短距離スキャンが crash しないことを確認する
  SHORT_RANGE_SCAN
END

DEF TEST_CROSS_DECIMAL_COURSE()
  INIT_GAME
  SET_POS 4, 4, 7, 4
  MOVE_WITHIN_QUADRANT 1.5, 2
  ASSERT (ENT_QX = 5)
  ASSERT (ENT_QY = 4)
  ASSERT (ENT_SX = 1)
  ASSERT (ENT_SY = 3)
  ASSERT (@SECTOR[ENT_SX, ENT_SY] = 1)
END

TEST_CROSS_EAST
TEST_CROSS_WEST
TEST_CROSS_SOUTH
TEST_CROSS_NORTH
TEST_CROSS_SCAN_NO_CRASH
TEST_CROSS_DECIMAL_COURSE

# ---- galaxy edge テスト ----

# X+ edge: QX=8, SX=8 から east 1 step -> galaxy 外 -> SX=8 に留まる
DEF TEST_EDGE_EAST()
  INIT_GAME
  SET_POS 8, 4, 8, 4
  MOVE_WITHIN_QUADRANT 1, 1
  ASSERT (ENT_QX = 8)
  ASSERT (ENT_SX = 8)
  ASSERT (ENT_QY = 4)
  ASSERT (ENT_SY = 4)
  ASSERT (@SECTOR[8, 4] = 1)
END

# X- edge: QX=1, SX=1 から west (course 5) 1 step -> galaxy 外 -> SX=1 に留まる
DEF TEST_EDGE_WEST()
  INIT_GAME
  SET_POS 1, 4, 1, 4
  MOVE_WITHIN_QUADRANT 5, 1
  ASSERT (ENT_QX = 1)
  ASSERT (ENT_SX = 1)
  ASSERT (ENT_QY = 4)
  ASSERT (ENT_SY = 4)
  ASSERT (@SECTOR[1, 4] = 1)
END

# Y+ edge: QY=8, SY=8 から south (course 7) 1 step -> galaxy 外 -> SY=8 に留まる
DEF TEST_EDGE_SOUTH()
  INIT_GAME
  SET_POS 4, 8, 4, 8
  MOVE_WITHIN_QUADRANT 7, 1
  ASSERT (ENT_QX = 4)
  ASSERT (ENT_SX = 4)
  ASSERT (ENT_QY = 8)
  ASSERT (ENT_SY = 8)
  ASSERT (@SECTOR[4, 8] = 1)
END

# Y- edge: QY=1, SY=1 から north (course 3) 1 step -> galaxy 外 -> SY=1 に留まる
DEF TEST_EDGE_NORTH()
  INIT_GAME
  SET_POS 4, 1, 4, 1
  MOVE_WITHIN_QUADRANT 3, 1
  ASSERT (ENT_QX = 4)
  ASSERT (ENT_SX = 4)
  ASSERT (ENT_QY = 1)
  ASSERT (ENT_SY = 1)
  ASSERT (@SECTOR[4, 1] = 1)
END

# corner diagonal: QX=8, QY=8, SX=8, SY=8 から SE (course 8, DX=+1 DY=+1) 1 step
# X/Y 両方が galaxy 外 -> (8,8) に留まる
DEF TEST_EDGE_CORNER_SE()
  INIT_GAME
  SET_POS 8, 8, 8, 8
  MOVE_WITHIN_QUADRANT 8, 1
  ASSERT (ENT_QX = 8)
  ASSERT (ENT_QY = 8)
  ASSERT (ENT_SX = 8)
  ASSERT (ENT_SY = 8)
  ASSERT (@SECTOR[8, 8] = 1)
END

DEF TEST_EDGE_DECIMAL_COURSE()
  INIT_GAME
  SET_POS 8, 4, 8, 4
  MOVE_WITHIN_QUADRANT 1.5, 1
  ASSERT (ENT_QX = 8)
  ASSERT (ENT_QY = 4)
  ASSERT (ENT_SX = 8)
  ASSERT (ENT_SY = 4)
  ASSERT (@SECTOR[8, 4] = 1)
END

# edge 後 @SECTOR に Enterprise が 1 つだけ存在する (重複なし)
# SX=4 から east: 4 step 進んで SX=8 で止まる -> 元 (4,4) は空
DEF TEST_EDGE_NO_DUPLICATE()
  INIT_GAME
  LET ENT_QX = 8
  SET_POS 8, 4, 4, 4
  MOVE_WITHIN_QUADRANT 1, 10
  # 最終有効 sector (8,4) に Enterprise
  ASSERT (@SECTOR[ENT_SX, ENT_SY] = 1)
  # 元の sector は空になっている
  ASSERT (@SECTOR[4, 4] = 0)
END

TEST_EDGE_EAST
TEST_EDGE_WEST
TEST_EDGE_SOUTH
TEST_EDGE_NORTH
TEST_EDGE_CORNER_SE
TEST_EDGE_DECIMAL_COURSE
TEST_EDGE_NO_DUPLICATE
