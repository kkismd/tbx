# trek/test_navigation_quadrant.tbx — NORMALIZE_SECTOR_CROSSING() direct tests
#
# 検証観点:
#   - X+ 越境: SX=9 -> QX+1, SX=1
#   - X- 越境: SX=0 -> QX-1, SX=8
#   - Y+ 越境: SY=9 -> QY+1, SY=1
#   - Y- 越境: SY=0 -> QY-1, SY=8
#   - X/Y 同時越境 (両方 +)
#   - X/Y 同時越境 (両方 -)
#   - galaxy 内なら NORM_IN_GALAXY = 1
#   - galaxy 外なら NORM_IN_GALAXY = 0 (QX=8, SX=9 -> QX=9)
#   - 越境なしなら NORM_CROSSED = 0

USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "scan.tbx"
USE "nav.tbx"
USE "../../lib/tests/helper.tbx"

# X+ 越境: QX=4, SX=9 -> QX=5, SX=1
DEF TEST_WRAP_X_PLUS()
  NORMALIZE_SECTOR_CROSSING 4, 4, 9, 4
  ASSERT (NORM_QX = 5)
  ASSERT (NORM_SX = 1)
  ASSERT (NORM_QY = 4)
  ASSERT (NORM_SY = 4)
  ASSERT (NORM_CROSSED = 1)
  ASSERT (NORM_IN_GALAXY = 1)
END

# X- 越境: QX=4, SX=0 -> QX=3, SX=8
DEF TEST_WRAP_X_MINUS()
  NORMALIZE_SECTOR_CROSSING 4, 4, 0, 4
  ASSERT (NORM_QX = 3)
  ASSERT (NORM_SX = 8)
  ASSERT (NORM_QY = 4)
  ASSERT (NORM_SY = 4)
  ASSERT (NORM_CROSSED = 1)
  ASSERT (NORM_IN_GALAXY = 1)
END

# Y+ 越境: QY=4, SY=9 -> QY=5, SY=1
DEF TEST_WRAP_Y_PLUS()
  NORMALIZE_SECTOR_CROSSING 4, 4, 4, 9
  ASSERT (NORM_QX = 4)
  ASSERT (NORM_SX = 4)
  ASSERT (NORM_QY = 5)
  ASSERT (NORM_SY = 1)
  ASSERT (NORM_CROSSED = 1)
  ASSERT (NORM_IN_GALAXY = 1)
END

# Y- 越境: QY=4, SY=0 -> QY=3, SY=8
DEF TEST_WRAP_Y_MINUS()
  NORMALIZE_SECTOR_CROSSING 4, 4, 4, 0
  ASSERT (NORM_QX = 4)
  ASSERT (NORM_SX = 4)
  ASSERT (NORM_QY = 3)
  ASSERT (NORM_SY = 8)
  ASSERT (NORM_CROSSED = 1)
  ASSERT (NORM_IN_GALAXY = 1)
END

# X/Y 同時越境 (+): SX=9, SY=9 -> QX+1, SX=1 / QY+1, SY=1
DEF TEST_WRAP_XY_PLUS()
  NORMALIZE_SECTOR_CROSSING 4, 4, 9, 9
  ASSERT (NORM_QX = 5)
  ASSERT (NORM_SX = 1)
  ASSERT (NORM_QY = 5)
  ASSERT (NORM_SY = 1)
  ASSERT (NORM_CROSSED = 1)
  ASSERT (NORM_IN_GALAXY = 1)
END

# X/Y 同時越境 (-): SX=0, SY=0 -> QX-1, SX=8 / QY-1, SY=8
DEF TEST_WRAP_XY_MINUS()
  NORMALIZE_SECTOR_CROSSING 4, 4, 0, 0
  ASSERT (NORM_QX = 3)
  ASSERT (NORM_SX = 8)
  ASSERT (NORM_QY = 3)
  ASSERT (NORM_SY = 8)
  ASSERT (NORM_CROSSED = 1)
  ASSERT (NORM_IN_GALAXY = 1)
END

# galaxy 外: QX=8, SX=9 -> QX=9 (1..8 外) -> NORM_IN_GALAXY = 0
DEF TEST_OUT_OF_GALAXY()
  NORMALIZE_SECTOR_CROSSING 8, 4, 9, 4
  ASSERT (NORM_QX = 9)
  ASSERT (NORM_SX = 1)
  ASSERT (NORM_IN_GALAXY = 0)
END

# galaxy 外 (Y): QY=8, SY=9 -> QY=9 -> NORM_IN_GALAXY = 0
DEF TEST_OUT_OF_GALAXY_Y()
  NORMALIZE_SECTOR_CROSSING 4, 8, 4, 9
  ASSERT (NORM_QY = 9)
  ASSERT (NORM_SY = 1)
  ASSERT (NORM_IN_GALAXY = 0)
END

# 越境なし: SX=4, SY=4 は bounds 内 -> NORM_CROSSED = 0, NORM_IN_GALAXY = 1
DEF TEST_NO_CROSSING()
  NORMALIZE_SECTOR_CROSSING 4, 4, 4, 4
  ASSERT (NORM_QX = 4)
  ASSERT (NORM_QY = 4)
  ASSERT (NORM_SX = 4)
  ASSERT (NORM_SY = 4)
  ASSERT (NORM_CROSSED = 0)
  ASSERT (NORM_IN_GALAXY = 1)
END

TEST_WRAP_X_PLUS
TEST_WRAP_X_MINUS
TEST_WRAP_Y_PLUS
TEST_WRAP_Y_MINUS
TEST_WRAP_XY_PLUS
TEST_WRAP_XY_MINUS
TEST_OUT_OF_GALAXY
TEST_OUT_OF_GALAXY_Y
TEST_NO_CROSSING
