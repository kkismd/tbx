USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "scan.tbx"
USE "nav.tbx"
USE "combat.tbx"
USE "command.tbx"
USE "../../lib/tests/helper.tbx"

DEF SET_DAMAGE_REPORT_SAMPLE()
  INIT_GAME
  LET @DAMAGE[1] = -2
  LET @DAMAGE[4] = -1
  LET @DAMAGE[7] = 3
END

DEF TEST_PRINT_DAMAGE_REPORT_OUTPUT()
  SET_DAMAGE_REPORT_SAMPLE
  PRINT_DAMAGE_REPORT
  ASSERT_OUTPUT "DAMAGE CONTROL REPORT\nWARP ENGINES: DAMAGED -2\nSHORT RANGE SENSORS: OPERATIONAL\nLONG RANGE SENSORS: OPERATIONAL\nPHASER CONTROL: DAMAGED -1\nPHOTON TUBES: OPERATIONAL\nDAMAGE CONTROL: OPERATIONAL\nSHIELD CONTROL: REPAIRING 3\nLIBRARY COMPUTER: OPERATIONAL\n"
END

DEF TEST_DISPATCH_COMMAND_6_PRINTS_DAMAGE_REPORT_OUTPUT()
  SET_DAMAGE_REPORT_SAMPLE
  DISPATCH_COMMAND 6
  ASSERT_OUTPUT "DAMAGE CONTROL REPORT\nWARP ENGINES: DAMAGED -2\nSHORT RANGE SENSORS: OPERATIONAL\nLONG RANGE SENSORS: OPERATIONAL\nPHASER CONTROL: DAMAGED -1\nPHOTON TUBES: OPERATIONAL\nDAMAGE CONTROL: OPERATIONAL\nSHIELD CONTROL: REPAIRING 3\nLIBRARY COMPUTER: OPERATIONAL\n"
END

TEST_PRINT_DAMAGE_REPORT_OUTPUT
TEST_DISPATCH_COMMAND_6_PRINTS_DAMAGE_REPORT_OUTPUT
