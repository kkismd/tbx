# trek/test_library_computer.tbx — library computer tests

USE "state.tbx"
USE "util.tbx"
USE "init.tbx"
USE "scan.tbx"
USE "combat.tbx"
USE "nav.tbx"
USE "library.tbx"
USE "command.tbx"
USE "../../lib/tests/helper.tbx"

DEF CLEAR_OUTPUT_BUFFER()
  VAR DISCARDED = GET_OUTPUT()
END

DEF SET_KLINGON(I, SX, SY, E)
  LET @K_X[I] = SX
  LET @K_Y[I] = SY
  LET @K_E[I] = E
END

DEF TEST_TORPEDO_DATA_DIRECTION_CARDINALS_MATCH_COURSE_CONVENTION()
  ASSERT (INT(TORPEDO_DATA_DIRECTION_FROM_DELTA(1, 0) * 10) = 10)
  ASSERT (INT(TORPEDO_DATA_DIRECTION_FROM_DELTA(0, -1) * 10) = 30)
  ASSERT (INT(TORPEDO_DATA_DIRECTION_FROM_DELTA(-1, 0) * 10) = 50)
  ASSERT (INT(TORPEDO_DATA_DIRECTION_FROM_DELTA(0, 1) * 10) = 70)
END

DEF TEST_TORPEDO_DATA_DIRECTION_DIAGONALS_MATCH_COURSE_CONVENTION()
  ASSERT (INT(TORPEDO_DATA_DIRECTION_FROM_DELTA(1, -1) * 10) = 20)
  ASSERT (INT(TORPEDO_DATA_DIRECTION_FROM_DELTA(-1, -1) * 10) = 40)
  ASSERT (INT(TORPEDO_DATA_DIRECTION_FROM_DELTA(-1, 1) * 10) = 60)
  ASSERT (INT(TORPEDO_DATA_DIRECTION_FROM_DELTA(1, 1) * 10) = 80)
END

DEF TEST_TORPEDO_DATA_DIRECTION_FRACTIONAL_CASE_IS_STABLE()
  ASSERT (TORPEDO_DATA_DIRECTION_FROM_DELTA(2, -1) = 1.5)
  ASSERT (TORPEDO_DATA_DIRECTION_FROM_DELTA(-2, -1) = 4.5)
END

DEF TEST_TORPEDO_DATA_DISTANCE_MATCHES_EUCLIDEAN_DELTA()
  ASSERT (TORPEDO_DATA_DISTANCE_FROM_DELTA(3, 4) = 5.0)
  ASSERT (TORPEDO_DATA_DISTANCE_FROM_DELTA(-3, -4) = 5.0)
END

DEF TEST_DISPATCH_LIBRARY_COMPUTER_OPTION_0()
  INIT_GAME
  LET ENT_QX = 4
  LET ENT_QY = 3
  LET @CHART[1, 1] = 101
  LET @CHART[4, 3] = 7
  LET @CHART[8, 8] = 305
  CLEAR_OUTPUT_BUFFER
  DISPATCH_LIBRARY_COMPUTER_OPTION 0
  ASSERT_OUTPUT "COMPUTER RECORD OF GALAXY FOR QUADRANT 3,4\n 101 000 000 000 000 000 000 000\n 000 000 000 000 000 000 000 000\n 000 000 000 007 000 000 000 000\n 000 000 000 000 000 000 000 000\n 000 000 000 000 000 000 000 000\n 000 000 000 000 000 000 000 000\n 000 000 000 000 000 000 000 000\n 000 000 000 000 000 000 000 305\n"
  ASSERT (@CHART[1, 1] = 101)
  ASSERT (@CHART[4, 3] = 7)
  ASSERT (@CHART[8, 8] = 305)
END

DEF TEST_DISPATCH_LIBRARY_COMPUTER_OPTION_0_AFTER_INIT_GAME_USES_ZERO_FILLED_CHART()
  INIT_GAME
  LET ENT_QX = 2
  LET ENT_QY = 1
  CLEAR_OUTPUT_BUFFER
  DISPATCH_LIBRARY_COMPUTER_OPTION 0
  ASSERT_OUTPUT "COMPUTER RECORD OF GALAXY FOR QUADRANT 1,2\n 000 000 000 000 000 000 000 000\n 000 000 000 000 000 000 000 000\n 000 000 000 000 000 000 000 000\n 000 000 000 000 000 000 000 000\n 000 000 000 000 000 000 000 000\n 000 000 000 000 000 000 000 000\n 000 000 000 000 000 000 000 000\n 000 000 000 000 000 000 000 000\n"
END

DEF TEST_DISPATCH_LIBRARY_COMPUTER_OPTION_1()
  LET KLINGONS_LEFT = 7
  LET START_STARDATE = 2200
  LET MISSION_DAYS = 30
  LET STARDATE = 2201.9
  LET BASES_LEFT = 2
  CLEAR_OUTPUT_BUFFER
  DISPATCH_LIBRARY_COMPUTER_OPTION 1
  ASSERT_OUTPUT "STATUS REPORT\nNUMBER OF KLINGONS LEFT =7\nNUMBER OF STARDATES LEFT =28\nNUMBER OF STARBASES LEFT =2\n"
END

DEF TEST_DISPATCH_LIBRARY_COMPUTER_OPTION_1_DOES_NOT_MUTATE_GAME_STATE()
  LET KLINGONS_LEFT = 4
  LET START_STARDATE = 3000
  LET MISSION_DAYS = 15
  LET STARDATE = 3004.5
  LET BASES_LEFT = 1
  LET ENERGY = 1800
  LET SHIELDS = 250
  CLEAR_OUTPUT_BUFFER
  DISPATCH_LIBRARY_COMPUTER_OPTION 1
  ASSERT (KLINGONS_LEFT = 4)
  ASSERT (START_STARDATE = 3000)
  ASSERT (MISSION_DAYS = 15)
  ASSERT (STARDATE = 3004.5)
  ASSERT (BASES_LEFT = 1)
  ASSERT (ENERGY = 1800)
  ASSERT (SHIELDS = 250)
END

DEF TEST_DISPATCH_LIBRARY_COMPUTER_OPTION_2()
  INIT_GAME
  LET ENT_SX = 4
  LET ENT_SY = 4
  SET_KLINGON 1, 6, 4, 200
  SET_KLINGON 2, 7, 3, 150
  SET_KLINGON 3, 8, 8, 0
  CLEAR_OUTPUT_BUFFER
  DISPATCH_LIBRARY_COMPUTER_OPTION 2
  ASSERT_OUTPUT "KLINGON AT SECTOR 6,4\nDIRECTION =1.0\nDISTANCE =2.0\nKLINGON AT SECTOR 7,3\nDIRECTION =1.3333333333333333\nDISTANCE =3.1622776601683795\n"
END

DEF TEST_DISPATCH_LIBRARY_COMPUTER_OPTION_2_PRINTS_SAFE_MESSAGE_WHEN_NO_KLINGONS_ARE_ALIVE()
  INIT_GAME
  LET ENT_SX = 4
  LET ENT_SY = 4
  SET_KLINGON 1, 6, 4, 0
  SET_KLINGON 2, 7, 3, 0
  SET_KLINGON 3, 8, 8, 0
  CLEAR_OUTPUT_BUFFER
  DISPATCH_LIBRARY_COMPUTER_OPTION 2
  ASSERT_OUTPUT "NO KLINGONS IN THIS QUADRANT\n"
END

DEF TEST_DISPATCH_LIBRARY_COMPUTER_OPTION_2_DOES_NOT_MUTATE_GAME_STATE()
  INIT_GAME
  LET ENT_QX = 4
  LET ENT_QY = 5
  LET ENT_SX = 4
  LET ENT_SY = 4
  LET KLINGONS_HERE = 2
  LET KLINGONS_LEFT = 7
  LET BASES_HERE = 1
  LET STARS_HERE = 3
  LET ENERGY = 1800
  LET SHIELDS = 250
  LET @GALAXY[ENT_QX, ENT_QY] = 213
  LET @CHART[ENT_QX, ENT_QY] = 213
  SET_KLINGON 1, 6, 4, 200
  SET_KLINGON 2, 7, 3, 150
  SET_KLINGON 3, 8, 8, 0
  CLEAR_OUTPUT_BUFFER
  DISPATCH_LIBRARY_COMPUTER_OPTION 2
  ASSERT (ENT_QX = 4)
  ASSERT (ENT_QY = 5)
  ASSERT (ENT_SX = 4)
  ASSERT (ENT_SY = 4)
  ASSERT (KLINGONS_HERE = 2)
  ASSERT (KLINGONS_LEFT = 7)
  ASSERT (BASES_HERE = 1)
  ASSERT (STARS_HERE = 3)
  ASSERT (ENERGY = 1800)
  ASSERT (SHIELDS = 250)
  ASSERT (@GALAXY[ENT_QX, ENT_QY] = 213)
  ASSERT (@CHART[ENT_QX, ENT_QY] = 213)
  ASSERT (@K_X[1] = 6)
  ASSERT (@K_Y[1] = 4)
  ASSERT (@K_E[1] = 200)
  ASSERT (@K_X[2] = 7)
  ASSERT (@K_Y[2] = 3)
  ASSERT (@K_E[2] = 150)
  ASSERT (@K_E[3] = 0)
END

DEF TEST_DISPATCH_LIBRARY_COMPUTER_OPTION_INVALID_PRINTS_MENU()
  CLEAR_OUTPUT_BUFFER
  DISPATCH_LIBRARY_COMPUTER_OPTION -1
  ASSERT_OUTPUT "FUNCTIONS AVAILABLE FROM COMPUTER\n   0 = CUMULATIVE GALACTIC RECORD\n   1 = STATUS REPORT\n   2 = PHOTON TORPEDO DATA\n"
END

DEF TEST_LIBRARY_COMPUTER_NO_INPUT_PRINTS_PROMPT_AND_MENU()
  INIT_GAME
  CLEAR_OUTPUT_BUFFER
  LIBRARY_COMPUTER
  # READ_NUMBER_OR() flushes the prompt before blocking, so GET_OUTPUT() sees the menu only.
  ASSERT_OUTPUT "FUNCTIONS AVAILABLE FROM COMPUTER\n   0 = CUMULATIVE GALACTIC RECORD\n   1 = STATUS REPORT\n   2 = PHOTON TORPEDO DATA\n"
END

DEF TEST_LIBRARY_COMPUTER_DISABLED_PRINTS_MESSAGE_AND_SKIPS_MENU()
  INIT_GAME
  SET_DEVICE_DAMAGE DAMAGE_SLOT_LIBRARY_COMPUTER(), -1
  CLEAR_OUTPUT_BUFFER
  LIBRARY_COMPUTER
  ASSERT_OUTPUT "COMPUTER DISABLED\n"
END

DEF TEST_DISPATCH_COMMAND_7_REACHES_LIBRARY_COMPUTER()
  INIT_GAME
  CLEAR_OUTPUT_BUFFER
  DISPATCH_COMMAND 7
  # The prompt is flushed to the interactive writer before input is attempted.
  ASSERT_OUTPUT "FUNCTIONS AVAILABLE FROM COMPUTER\n   0 = CUMULATIVE GALACTIC RECORD\n   1 = STATUS REPORT\n   2 = PHOTON TORPEDO DATA\n"
END

DEF TEST_DISPATCH_COMMAND_7_COMPUTER_DISABLED_RETURNS_SAFELY()
  INIT_GAME
  SET_DEVICE_DAMAGE DAMAGE_SLOT_LIBRARY_COMPUTER(), -1
  CLEAR_OUTPUT_BUFFER
  DISPATCH_COMMAND 7
  ASSERT_OUTPUT "COMPUTER DISABLED\n"
END

TEST_DISPATCH_LIBRARY_COMPUTER_OPTION_0
TEST_DISPATCH_LIBRARY_COMPUTER_OPTION_0_AFTER_INIT_GAME_USES_ZERO_FILLED_CHART
TEST_DISPATCH_LIBRARY_COMPUTER_OPTION_1
TEST_DISPATCH_LIBRARY_COMPUTER_OPTION_1_DOES_NOT_MUTATE_GAME_STATE
TEST_TORPEDO_DATA_DIRECTION_CARDINALS_MATCH_COURSE_CONVENTION
TEST_TORPEDO_DATA_DIRECTION_DIAGONALS_MATCH_COURSE_CONVENTION
TEST_TORPEDO_DATA_DIRECTION_FRACTIONAL_CASE_IS_STABLE
TEST_TORPEDO_DATA_DISTANCE_MATCHES_EUCLIDEAN_DELTA
TEST_DISPATCH_LIBRARY_COMPUTER_OPTION_2
TEST_DISPATCH_LIBRARY_COMPUTER_OPTION_2_PRINTS_SAFE_MESSAGE_WHEN_NO_KLINGONS_ARE_ALIVE
TEST_DISPATCH_LIBRARY_COMPUTER_OPTION_2_DOES_NOT_MUTATE_GAME_STATE
TEST_DISPATCH_LIBRARY_COMPUTER_OPTION_INVALID_PRINTS_MENU
TEST_LIBRARY_COMPUTER_NO_INPUT_PRINTS_PROMPT_AND_MENU
TEST_LIBRARY_COMPUTER_DISABLED_PRINTS_MESSAGE_AND_SKIPS_MENU
TEST_DISPATCH_COMMAND_7_REACHES_LIBRARY_COMPUTER
TEST_DISPATCH_COMMAND_7_COMPUTER_DISABLED_RETURNS_SAFELY
