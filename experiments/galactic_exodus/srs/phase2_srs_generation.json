          "tie_break": ["LOWER_X", "LOWER_Y"]
        },
        "east_west": {
          "primary": "MIN_ABS_DEST_Y_MINUS_SOURCE_Y",
          "tie_break": ["LOWER_Y", "LOWER_X"]
        },
        "no_candidate_behavior": "INVALID_MAP_RETRY"
      }
    },
