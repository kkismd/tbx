# lib/tests/test_short_circuit_logical_ops.tbx - short-circuit logical operators
USE "lib/tests/helper.tbx"

DEF FAIL_IF_EVALUATED()
  ASSERT_FAIL
  RETURN 1
END

PUTVAL (0 && FAIL_IF_EVALUATED())
ASSERT_OUTPUT "FALSE"
PUTVAL (1 || FAIL_IF_EVALUATED())
ASSERT_OUTPUT "TRUE"

VAR HIT
SET &HIT, 0

DEF MARK()
  LET HIT = HIT + 1
  RETURN 123
END

ASSERT (1 && MARK())
ASSERT HIT = 1
ASSERT (0 || MARK())
ASSERT HIT = 2

DIM @A[1]
VAR I
SET &I, 2

DEF CHECK_ARRAY_GUARD()
  IF (I <= ARRAY_LEN(@A)) && (@A[I] = 0)
    ASSERT_FAIL
  ENDIF
  RETURN 1
END

ASSERT CHECK_ARRAY_GUARD()

PUTVAL (0 && 123)
PUTVAL (1 && 123)
PUTVAL (123 || 0)
PUTVAL (0 || 0)
ASSERT_OUTPUT "FALSETRUETRUEFALSE"

ASSERT (6 & 3) = 2
ASSERT (4 | 1) = 5
