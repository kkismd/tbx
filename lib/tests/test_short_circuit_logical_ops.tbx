# lib/tests/test_short_circuit_logical_ops.tbx - short-circuit logical operators
USE "lib/tests/helper.tbx"

DEF FAIL_IF_EVALUATED()
  ASSERT_FAIL
  RETURN 1
END

PUTVAL (FALSE && FAIL_IF_EVALUATED())
ASSERT_OUTPUT "FALSE"
PUTVAL (TRUE || FAIL_IF_EVALUATED())
ASSERT_OUTPUT "TRUE"

VAR HIT
SET &HIT, 0

DEF MARK()
  LET HIT = HIT + 1
  RETURN 123
END

ASSERT (TRUE && MARK())
ASSERT HIT = 1
ASSERT (FALSE || MARK())
ASSERT HIT = 2

DIM @A[1]
VAR I
SET &I, 2

DEF CHECK_ARRAY_GUARD()
  IF (I <= ARRAY_LEN(@A)) && (@A[I] = 0)
    ASSERT_FAIL
  ENDIF
  RETURN 1
END

ASSERT CHECK_ARRAY_GUARD()

PUTVAL (FALSE && 123)
PUTVAL (TRUE && 123)
PUTVAL (123 || FALSE)
PUTVAL (FALSE || FALSE)
ASSERT_OUTPUT "FALSETRUETRUEFALSE"

ASSERT (6 & 3) = 2
ASSERT (4 | 1) = 5

DEF BOOL_TO_ONE(X)
  IF X
    RETURN 1
  ENDIF
  RETURN 0
END

DEF CHECK_DIM_SHORT_CIRCUIT_SIZE()
  DIM @D[BOOL_TO_ONE(FALSE || TRUE)]
  DIM @E[BOOL_TO_ONE(TRUE && TRUE)]
  RETURN ARRAY_LEN(@D) + ARRAY_LEN(@E)
END

ASSERT CHECK_DIM_SHORT_CIRCUIT_SIZE() = 2

DEF CHECK_LET_SHORT_CIRCUIT_INDEX()
  DIM @C[1]
  LET @C[BOOL_TO_ONE(FALSE || TRUE)] = 42
  RETURN @C[1]
END

ASSERT CHECK_LET_SHORT_CIRCUIT_INDEX() = 42
