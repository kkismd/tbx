# lib/tests/test_short_circuit_logical_ops.tbx - short-circuit logical operators
USE "lib/tests/helper.tbx"

DEF FAIL_IF_EVALUATED()
  ASSERT_FAIL
  RETURN 1
END

PUTVAL (0 && FAIL_IF_EVALUATED())
ASSERT_OUTPUT "FALSE"
PUTVAL (1 || FAIL_IF_EVALUATED())
ASSERT_OUTPUT "TRUE"

VAR HIT
SET &HIT, 0

DEF MARK()
  LET HIT = HIT + 1
  RETURN 123
END

ASSERT (1 && MARK())
ASSERT HIT = 1
ASSERT (0 || MARK())
ASSERT HIT = 2

DIM @A[1]
VAR I
SET &I, 2

DEF CHECK_ARRAY_GUARD()
  IF (I <= ARRAY_LEN(@A)) && (@A[I] = 0)
    ASSERT_FAIL
  ENDIF
  RETURN 1
END

ASSERT CHECK_ARRAY_GUARD()

PUTVAL (0 && 123)
PUTVAL (1 && 123)
PUTVAL (123 || 0)
PUTVAL (0 || 0)
ASSERT_OUTPUT "FALSETRUETRUEFALSE"

ASSERT (6 & 3) = 2
ASSERT (4 | 1) = 5

DEF BOOL_TO_ONE(X)
  IF X
    RETURN 1
  ENDIF
  RETURN 0
END

DEF CHECK_DIM_SHORT_CIRCUIT_SIZE()
  DIM @D[BOOL_TO_ONE(0 || 1)]
  DIM @E[BOOL_TO_ONE(1 && 2)]
  RETURN ARRAY_LEN(@D) + ARRAY_LEN(@E)
END

ASSERT CHECK_DIM_SHORT_CIRCUIT_SIZE() = 2

DEF CHECK_LET_SHORT_CIRCUIT_INDEX()
  DIM @C[1]
  LET @C[BOOL_TO_ONE(0 || 1)] = 42
  RETURN @C[1]
END

ASSERT CHECK_LET_SHORT_CIRCUIT_INDEX() = 42
