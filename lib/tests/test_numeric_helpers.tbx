USE "lib/tests/helper.tbx"

ASSERT ABS(-3) = 3
ASSERT ABS(2.5) = 2.5

ASSERT MIN(3, 7) = 3
ASSERT MIN(3.5, 1.25) = 1.25

ASSERT MAX(3, 7) = 7
ASSERT MAX(3.5, 1.25) = 3.5

ASSERT CLAMP(-1, 0, 10) = 0
ASSERT CLAMP(4, 0, 10) = 4
ASSERT CLAMP(12, 0, 10) = 10

ASSERT ROUND(1.4) = 1
ASSERT ROUND(1.5) = 2
ASSERT ROUND(-1.4) = -1
ASSERT ROUND(-1.5) = -2
ASSERT ROUND(0.5) = 1
ASSERT ROUND(-0.5) = -1

ASSERT LERP(10, 20, 0.0) = 10.0
ASSERT LERP(10, 20, 0.25) = 12.5
ASSERT LERP(10, 20, 1.0) = 20.0

ASSERT IN_RANGE(1, 1, 3)
ASSERT IN_RANGE(3, 1, 3)
ASSERT_FALSE IN_RANGE(0, 1, 3)
ASSERT_FALSE IN_RANGE(4, 1, 3)
