# lib/tests/test_select_case.tbx
# TBX tests for SELECT ... CASE ... CASE_ELSE ... ENDSEL.
USE "lib/tests/helper.tbx"

DEF SIGN3(X)
  SELECT X
  CASE 1
    RETURN 10
  CASE 0
    RETURN 0
  CASE_ELSE
    RETURN -10
  ENDSEL
END

ASSERT SIGN3(1) = 10
ASSERT SIGN3(0) = 0
ASSERT SIGN3(7) = -10

DEF MATCH_ONE(X)
  SELECT X
  CASE 1
    RETURN 1
  ENDSEL
  RETURN 0
END

ASSERT MATCH_ONE(1) = 1
ASSERT MATCH_ONE(2) = 0

DEF MATCH_ONE_THEN_CONTINUE(X)
  SELECT X
  CASE 1
    PUTSTR "hit"
  ENDSEL
  PUTDEC X
END

MATCH_ONE_THEN_CONTINUE(1)

DEF SELECT_STR(S)
  SELECT S
  CASE "hi"
    RETURN 1
  CASE "bye"
    RETURN 2
  CASE_ELSE
    RETURN 0
  ENDSEL
END

ASSERT SELECT_STR("hi") = 1
ASSERT SELECT_STR("bye") = 2
ASSERT SELECT_STR("nope") = 0

DEF NESTED_SELECT(X)
  SELECT X
  CASE 1
    SELECT X + 1
    CASE 2
      RETURN 12
    ENDSEL
  CASE_ELSE
    RETURN 0
  ENDSEL
END

ASSERT NESTED_SELECT(1) = 12
ASSERT NESTED_SELECT(3) = 0
