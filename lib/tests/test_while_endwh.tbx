REM lib/tests/test_while_endwh.tbx — TBX tests for WHILE/ENDWH control structures
USE "lib/tests/helper.tbx"
USE "lib/basic.tbx"

REM Count up: loop body must execute the expected number of times.
DEF COUNT_UP(N)
  VAR I
  VAR S
  SET &I, 0
  SET &S, 0
  WHILE I < N
    SET &S, S + 1
    SET &I, I + 1
  ENDWH
  RETURN S
END
ASSERT_MSG COUNT_UP(5) = 5, "COUNT_UP: 5 iterations"
ASSERT_MSG COUNT_UP(1) = 1, "COUNT_UP: 1 iteration"

REM Condition false from the start: body must not execute at all.
ASSERT_MSG COUNT_UP(0) = 0, "COUNT_UP: zero iterations"

REM Count down: accumulate sum 3+2+1 = 6.
DEF SUM_DOWN(N)
  VAR I
  VAR S
  SET &I, N
  SET &S, 0
  WHILE I > 0
    SET &S, S + I
    SET &I, I - 1
  ENDWH
  RETURN S
END
ASSERT_MSG SUM_DOWN(3) = 6, "SUM_DOWN: 3+2+1=6"
ASSERT_MSG SUM_DOWN(0) = 0, "SUM_DOWN: zero iterations"

REM Nested WHILE: multiplication by repeated addition.
DEF MULTIPLY(A, B)
  VAR I
  VAR J
  VAR R
  SET &I, 0
  SET &R, 0
  WHILE I < A
    SET &J, 0
    WHILE J < B
      SET &R, R + 1
      SET &J, J + 1
    ENDWH
    SET &I, I + 1
  ENDWH
  RETURN R
END
ASSERT_MSG MULTIPLY(3, 4) = 12, "MULTIPLY: 3*4=12"
ASSERT_MSG MULTIPLY(0, 5) = 0, "MULTIPLY: outer loop skipped"
ASSERT_MSG MULTIPLY(5, 0) = 0, "MULTIPLY: inner loop skipped"

REM WHILE with nested IF/ENDIF: count positive integers in 1..N.
DEF COUNT_POS(N)
  VAR I
  VAR S
  SET &I, 0
  SET &S, 0
  WHILE I <= N
    IF I > 0
      SET &S, S + 1
    ENDIF
    SET &I, I + 1
  ENDWH
  RETURN S
END
ASSERT_MSG COUNT_POS(3) = 3, "COUNT_POS: positives in [0..3]"
ASSERT_MSG COUNT_POS(0) = 0, "COUNT_POS: no positives when N=0"

REM IF/ENDIF containing WHILE/ENDWH: verify compile-stack symmetry in both nesting orders.
DEF COND_SUM(FLAG, N)
  VAR I
  VAR S
  SET &I, 0
  SET &S, 0
  IF FLAG > 0
    WHILE I < N
      SET &S, S + I
      SET &I, I + 1
    ENDWH
  ENDIF
  RETURN S
END
ASSERT_MSG COND_SUM(1, 4) = 6, "COND_SUM: flag=1 sums 0+1+2+3=6"
ASSERT_MSG COND_SUM(0, 4) = 0, "COND_SUM: flag=0 skips loop"

REM WHILE loop with early RETURN: return the first element greater than THRESHOLD.
DEF FIND_FIRST_GT(N, THRESHOLD)
  VAR I
  SET &I, 0
  WHILE I < N
    IF I > THRESHOLD
      RETURN I
    ENDIF
    SET &I, I + 1
  ENDWH
  RETURN -1
END
ASSERT_MSG FIND_FIRST_GT(10, 3) = 4, "FIND_FIRST_GT: first element > 3 in 0..9 is 4"
ASSERT_MSG FIND_FIRST_GT(3, 5) = -1, "FIND_FIRST_GT: no element > 5 in 0..2"
