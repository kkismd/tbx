REM lib/tests/test_if_endif.tbx — TBX tests for IF/ENDIF control structures
USE "lib/tests/helper.tbx"

DEF CHECK_POS(X)
  IF X > 0
    RETURN 1
  ENDIF
  RETURN 0
END
ASSERT CHECK_POS(5) = 1
ASSERT CHECK_POS(0) = 0
ASSERT CHECK_POS(-3) = 0

DEF SIGN(X)
  IF X > 0
    RETURN 1
  ENDIF
  IF X < 0
    RETURN -1
  ENDIF
  RETURN 0
END
ASSERT SIGN(7) = 1
ASSERT SIGN(-7) = -1
ASSERT SIGN(0) = 0

DEF NESTED(X)
  IF X > 0
    IF X > 10
      RETURN 2
    ENDIF
    RETURN 1
  ENDIF
  RETURN 0
END
ASSERT NESTED(15) = 2
ASSERT NESTED(5) = 1
ASSERT NESTED(-1) = 0
