# lib/tests/test_rnd.tbx — TBX integration tests for RND / RANDOMIZE / SHUFFLE
USE "lib/tests/helper.tbx"

# --- RND(1) must always return 1 ---

ASSERT RND(1) = 1

# --- RND(6) result must be in [1, 6] ---

VAR X
SET &X, RND(6)
ASSERT X >= 1
ASSERT X <= 6

# --- RANDOMIZE must complete without error ---

RANDOMIZE

