# lib/tests/helper.tbx — test support words for TBX library tests

DEF ASSERT(COND)
  IF COND
    RETURN
  ENDIF
  ASSERT_FAIL
END

DEF ASSERT_MSG(COND, MSG)
  IF COND
    RETURN
  ENDIF
  ASSERT_FAIL_MSG MSG
END

DEF ASSERT_OUTPUT(EXPECTED)
  ASSERT_MSG STR_EQ(GET_OUTPUT(), EXPECTED), "output mismatch"
END
