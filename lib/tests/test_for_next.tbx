# lib/tests/test_for_next.tbx — TBX tests for FOR/NEXT control structures
USE "lib/tests/helper.tbx"

# --- Basic counting loop: sum 1..10 (step 1 fixed) ---

DEF SUM_1_TO_10
  VAR I
  VAR S
  SET &S, 0
  FOR &I, 10
    SET &S, S + I
  NEXT
  RETURN S
END
ASSERT SUM_1_TO_10() = 55

# --- Loop that does not execute: end < 1 ---

DEF ZERO_ITERATIONS
  VAR I
  VAR C
  SET &C, 0
  FOR &I, 0
    SET &C, C + 1
  NEXT
  RETURN C
END
ASSERT ZERO_ITERATIONS() = 0

# --- Single iteration: end = 1 ---

DEF ONE_ITERATION
  VAR I
  VAR C
  SET &C, 0
  FOR &I, 1
    SET &C, C + 1
  NEXT
  RETURN C
END
ASSERT ONE_ITERATION() = 1

# --- Nested FOR loops: 3 x 4 = 12 iterations ---

DEF NESTED_FOR
  VAR I
  VAR J
  VAR S
  SET &S, 0
  FOR &I, 3
    FOR &J, 4
      SET &S, S + 1
    NEXT
  NEXT
  RETURN S
END
ASSERT NESTED_FOR() = 12

# --- Step-2 loop using WHILE: sum of odd numbers 1, 3, 5, 7, 9 = 25 ---

DEF SUM_ODD_1_TO_10
  VAR I
  VAR S
  SET &I, 1
  SET &S, 0
  WHILE I <= 9
    SET &S, S + I
    SET &I, I + 2
  ENDWH
  RETURN S
END
ASSERT SUM_ODD_1_TO_10() = 25

# --- Even-step loop using WHILE: count 2, 4, 6, 8, 10 = 5 iterations ---

DEF COUNT_EVEN
  VAR I
  VAR C
  SET &I, 2
  SET &C, 0
  WHILE I <= 10
    SET &C, C + 1
    SET &I, I + 2
  ENDWH
  RETURN C
END
ASSERT COUNT_EVEN() = 5
