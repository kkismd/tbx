# lib/tests/test_if_elsif_else.tbx — TBX tests for IF/ELSIF/ELSE/ENDIF
USE "lib/tests/helper.tbx"

# --- IF ... ELSE ... ENDIF ---

DEF SIGN_WITH_ELSE(X)
  IF X > 0
    RETURN 1
  ELSE
    RETURN -1
  ENDIF
END
ASSERT SIGN_WITH_ELSE(5) = 1
ASSERT SIGN_WITH_ELSE(-3) = -1
ASSERT SIGN_WITH_ELSE(0) = -1

# --- IF ... ELSIF ... ENDIF (no ELSE) ---

DEF CLASSIFY(X)
  IF X < 0
    RETURN -1
  ELSIF X = 0
    RETURN 0
  ENDIF
  RETURN 1
END
ASSERT CLASSIFY(-5) = -1
ASSERT CLASSIFY(0) = 0
ASSERT CLASSIFY(7) = 1

# --- IF ... ELSIF ... ELSE ... ENDIF (ELSIF x1 + ELSE; N=1 + ELSE path) ---

DEF SIGN3(X)
  IF X > 0
    RETURN 1
  ELSIF X < 0
    RETURN -1
  ELSE
    RETURN 0
  ENDIF
END
ASSERT SIGN3(10) = 1
ASSERT SIGN3(-10) = -1
ASSERT SIGN3(0) = 0

# --- IF ... ELSIF ... ELSE ... ENDIF ---

DEF GRADE(X)
  IF X >= 90
    RETURN 4
  ELSIF X >= 70
    RETURN 3
  ELSIF X >= 50
    RETURN 2
  ELSE
    RETURN 1
  ENDIF
END
ASSERT GRADE(95) = 4
ASSERT GRADE(90) = 4
ASSERT GRADE(89) = 3
ASSERT GRADE(80) = 3
ASSERT GRADE(70) = 3
ASSERT GRADE(69) = 2
ASSERT GRADE(60) = 2
ASSERT GRADE(50) = 2
ASSERT GRADE(49) = 1
ASSERT GRADE(40) = 1

# --- IF ... ELSIF ... ELSIF ... ENDIF (multiple ELSIF, no ELSE) ---

DEF SEASON(M)
  IF M = 12
    RETURN 1
  ELSIF M = 1
    RETURN 1
  ELSIF M = 2
    RETURN 1
  ENDIF
  RETURN 0
END
ASSERT SEASON(12) = 1
ASSERT SEASON(1) = 1
ASSERT SEASON(2) = 1
ASSERT SEASON(3) = 0
ASSERT SEASON(6) = 0
ASSERT SEASON(7) = 0
ASSERT SEASON(11) = 0

# --- Backward compatibility: plain IF ... ENDIF without ELSIF/ELSE ---

DEF IS_POS(X)
  IF X > 0
    RETURN 1
  ENDIF
  RETURN 0
END
ASSERT IS_POS(3) = 1
ASSERT IS_POS(0) = 0
ASSERT IS_POS(-1) = 0

# --- Nested: IF...ELSIF inside outer IF...ENDIF ---

DEF NESTED_ELSIF(X, Y)
  IF X > 0
    IF Y > 0
      RETURN 1
    ELSIF Y = 0
      RETURN 2
    ELSE
      RETURN 3
    ENDIF
  ENDIF
  RETURN 0
END
ASSERT NESTED_ELSIF(1, 1) = 1
ASSERT NESTED_ELSIF(1, 0) = 2
ASSERT NESTED_ELSIF(1, -1) = 3
ASSERT NESTED_ELSIF(-1, 1) = 0

# --- ASSERT_MSG integration ---
ASSERT_MSG SIGN_WITH_ELSE(5) = 1, "SIGN_WITH_ELSE: positive"
ASSERT_MSG SIGN_WITH_ELSE(-3) = -1, "SIGN_WITH_ELSE: negative"
ASSERT_MSG GRADE(95) = 4, "GRADE: A"
ASSERT_MSG GRADE(40) = 1, "GRADE: D"
ASSERT_MSG NESTED_ELSIF(1, 0) = 2, "NESTED_ELSIF: x>0 y=0"
