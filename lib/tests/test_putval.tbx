# lib/tests/test_putval.tbx — TBX integration tests for PUTVAL primitive
USE "lib/tests/helper.tbx"

# --- PUTVAL with Int ---

PUTVAL 42
ASSERT_OUTPUT "42"

# --- PUTVAL with Float ---

PUTVAL 3.14
ASSERT_OUTPUT "3.14"

# --- PUTVAL with whole Float must include decimal point ---

PUTVAL 1.0
ASSERT_OUTPUT "1.0"

# --- PUTVAL with Bool TRUE ---

PUTVAL TRUE
ASSERT_OUTPUT "TRUE"

# --- PUTVAL with Bool FALSE ---

PUTVAL FALSE
ASSERT_OUTPUT "FALSE"

# --- PUTVAL with Str ---

PUTVAL "hello"
ASSERT_OUTPUT "hello"
