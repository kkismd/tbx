# lib/tests/test_bool_constants.tbx - surface TRUE/FALSE constants
USE "lib/tests/helper.tbx"

PUTVAL TRUE
PUTVAL FALSE
PUTVAL true
PUTVAL False
ASSERT_OUTPUT "TRUEFALSETRUEFALSE"

DEF CHECK_BOOL_CONSTANT_ASSIGNMENT()
  VAR X
  VAR Y
  LET X = TRUE
  LET Y = FALSE
  RETURN X = TRUE && Y = FALSE
END

ASSERT CHECK_BOOL_CONSTANT_ASSIGNMENT()
ASSERT TRUE = (1 = 1)
ASSERT FALSE = (1 = 0)
